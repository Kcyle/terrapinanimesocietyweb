# Admin password for the screening editor
# Set this to whatever password you want admins to use
ADMIN_PASSWORD=your_secure_password_here

# GitHub Personal Access Token with repo write permissions
# Create one at: https://github.com/settings/tokens
# Required scopes: repo (or just public_repo if repo is public)
GITHUB_TOKEN=ghp_your_github_token_here

# GitHub repository details (optional - defaults shown)
GITHUB_OWNER=Kcyle
GITHUB_REPO=terrapinanimesocietyweb

# Supabase (for Maid Cafe reservation system)
# Create a project at https://supabase.com and run maidcafe-schema.sql
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth (for Maid Cafe sign-in)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set authorized JavaScript origins to your domain
PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
