---
import subgroups from '../data/subgroups.json';
import activities from '../data/activities.json';

const { list } = subgroups;
---

<div class="activities__bg" data-activities-bg></div>

<div class="activities__void" data-activities-void>
  {list.map((subgroup, index) => (
    <div class="activities__sky-biome" {...{ [`data-sky-biome-${index + 1}`]: true }}>
      <img src={subgroup.previewImage} alt="" class="sky-biome-blur" />
      <img src={subgroup.previewImage} alt="" class="sky-biome-img" />
    </div>
  ))}
</div>

<div class="subgroups-intro" data-subgroups-intro>
  <div class="subgroups-intro__bg"></div>
  <div class="subgroups-intro__content">
    <h2 class="subgroups-intro__heading" data-subgroups-heading>{subgroups.heading}</h2>
    <p class="subgroups-intro__subtitle" data-subgroups-subtitle>{subgroups.subtitle}</p>
    <div class="subgroups-intro__previews" data-subgroups-previews>
      {list.map((subgroup) => (
        <div class={subgroup.id === 'bookclub' ? 'subgroups-intro__card subgroups-intro__card--bookclub' : 'subgroups-intro__card'}>
          <img src={subgroup.previewImage} alt={subgroup.name} class="subgroups-intro__card-img" />
          <span class="subgroups-intro__card-name">{subgroup.name}</span>
        </div>
      ))}
    </div>
  </div>
</div>

{list.map((subgroup, index) => (
  <div class={`subgroup subgroup--${subgroup.id}`} {...{ [`data-subgroup-${index + 1}`]: true }}>
    <div class="subgroup__left" {...{ [`data-subgroup-${index + 1}-left`]: true }}>
      <h3 class={`subgroup__name subgroup__name--${subgroup.id}`}>{subgroup.name}</h3>
      <p class="subgroup__tagline">{subgroup.tagline}</p>
    </div>
    <div class="subgroup__right" {...{ [`data-subgroup-${index + 1}-right`]: true }}>
      <div class="subgroup__info">
        {subgroup.meets && (
          <p class="subgroup__time"><span class="subgroup__label">Meets</span>{subgroup.meets}</p>
        )}
        <p class="subgroup__leader"><span class="subgroup__label">Leader</span>{subgroup.leader}</p>
        <p class="subgroup__desc">{subgroup.description}</p>
      </div>
    </div>
    {subgroup.photos.map((photo) => (
      <div
        class={`subgroup__photo subgroup__photo--${photo.side}`}
        {...{ [`data-subgroup-${index + 1}-photo-${photo.side}`]: true }}
      >
        <img src={photo.src} alt={photo.alt} />
      </div>
    ))}
  </div>
))}

<div class="activities-content" data-activities-content>
  <div class="activities__character" data-activities-character>
    <img src={activities.characterImage} alt={activities.characterAlt} class="activities__character-image" />
  </div>

  <div class="activities__main">
    <h1 class="activities__title" data-activities-title>{activities.title}</h1>
    <p class="activities__description" data-activities-description>{activities.description}</p>
  </div>

  <div class="activities__card-pile">
    {activities.cards.map((card) => (
      <div class={`activities__card card--${card.id}`} data-activity-card>
        <h3 class="activities__card-name">{card.name}</h3>
        {card.feature && <span class="activities__card-feat">{card.feature}</span>}
        <p class="activities__card-desc">{card.description}</p>
      </div>
    ))}
  </div>
</div>

<style>
  .activities__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-image: url('/images/Backgrounds/makima.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 25;
    visibility: hidden;
    opacity: 0;
    will-change: opacity, visibility;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .activities__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)),
      radial-gradient(ellipse at center, transparent 20%, rgba(0, 0, 0, 0.5) 70%, rgba(0, 0, 0, 0.85) 100%),
      linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, transparent 40%),
      linear-gradient(to bottom, rgba(0, 0, 0, 0.4) 0%, transparent 30%);
    pointer-events: none;
  }

  .activities-content {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100vh;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    overflow: visible;
    z-index: 30;
    will-change: transform, opacity;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .activities__character {
    position: absolute;
    right: 0;
    bottom: 0;
    z-index: 2;
    pointer-events: none;
    will-change: transform;
    backface-visibility: hidden;
  }

  .activities__character-image {
    height: 85vh;
    width: auto;
    max-width: 45vw;
    object-fit: contain;
    object-position: bottom right;
    display: block;
  }

  .activities__main {
    position: relative;
    z-index: 5;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 1.25vw;
    padding-top: 11.11vh;
  }

  .activities__title {
    font-family: 'Inter', sans-serif;
    font-size: 4.17vw;
    font-weight: 800;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin: 0;
    text-shadow: 0 4px 40px rgba(0, 0, 0, 0.9), 0 2px 10px rgba(0, 0, 0, 0.7);
  }

  .activities__description {
    font-family: 'Inter', sans-serif;
    font-size: 0.92vw;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.9);
    max-width: 33.33vw;
    line-height: 1.5;
    margin: 1.48vh 0 0;
    text-shadow: 0 2px 15px rgba(0, 0, 0, 0.8);
  }

  .activities__card-pile {
    position: absolute;
    left: 7.25vw;
    top: 40vh;
    width: 25vw;
    height: 28vh;
    z-index: 4;
    pointer-events: none;
  }

  .activities__card {
    position: absolute;
    width: 25vw;
    height: 28vh;
    background: #fff;
    border: 0.17vw solid #000;
    border-radius: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.56vh;
    padding: 2.22vh 1.25vw;
    will-change: transform;
    backface-visibility: hidden;
    overflow: hidden;
    box-shadow:
      0.25vw 0.44vh 0 #000,
      inset 0 0 0 0.083vw #000;
  }

  .activities__card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, #000 0.04vw, transparent 0.04vw);
    background-size: 0.25vw 0.25vw;
    opacity: 0.12;
    pointer-events: none;
    z-index: 0;
  }

  .activities__card::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 0.083vw,
      rgba(0, 0, 0, 0.03) 0.083vw,
      rgba(0, 0, 0, 0.03) 0.17vw
    );
    pointer-events: none;
    z-index: 0;
  }

  .activities__card-name {
    position: relative;
    z-index: 2;
    font-family: 'Inter', sans-serif;
    font-size: 1.35vw;
    font-weight: 900;
    color: #000;
    text-align: left;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.2;
    padding: 0.15vh 0 0.5vh;
    border-bottom: 0.22vh solid #000;
    text-shadow: 1px 1px 0 rgba(0,0,0,0.1);
    width: 100%;
  }

  .activities__card-feat {
    position: relative;
    z-index: 2;
    font-family: 'Inter', sans-serif;
    font-size: 0.67vw;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: #000;
    padding: 0.3vh 0.42vw;
    margin: 0.19vh 0 0;
    line-height: 1.2;
  }

  .activities__card-desc {
    position: relative;
    z-index: 2;
    font-family: 'Inter', sans-serif;
    font-size: 0.83vw;
    font-weight: 600;
    color: #000;
    text-align: left;
    line-height: 1.5;
    margin: 0.37vh 0 0;
    max-width: 100%;
    width: 100%;
  }

  @media (max-width: 768px) {
    .activities__main {
      padding: 1rem;
      padding-top: 100px;
    }

    .activities__title {
      font-size: 36px;
    }

    .activities__description {
      font-size: 14px;
      max-width: 100%;
      margin-top: 1rem;
      line-height: 1.5;
    }

    .activities__character-image {
      height: 50vh;
      max-width: 60vw;
    }

    .activities__card-pile {
      left: 1rem;
      top: 40vh;
      width: 280px;
      height: 200px;
    }

    .activities__card {
      width: 280px;
      height: 200px;
      padding: 1.25rem;
      border: 3px solid #000;
    }

    .activities__card-name {
      font-size: 16px;
      line-height: 1.2;
      border-bottom: 2px solid #000;
    }

    .activities__card-feat {
      font-size: 10px;
      padding: 3px 8px;
    }

    .activities__card-desc {
      font-size: 13px;
      line-height: 1.4;
      max-width: 100%;
    }
  }

  .activities__void {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    z-index: 35;
    pointer-events: none;
    will-change: opacity;
    overflow: hidden;
  }

  .activities__sky-biome {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    background: #0a0a18;
    overflow: hidden;
  }

  .activities__sky-biome:first-child {
    opacity: 0;
  }

  .sky-biome-blur {
    position: absolute;
    inset: -20px;
    width: calc(100% + 40px);
    height: calc(100% + 40px);
    object-fit: cover;
    object-position: center;
    filter: blur(30px) brightness(0.7);
    transform: scale(1.1);
    z-index: 1;
  }

  .sky-biome-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    z-index: 2;

    -webkit-mask-image: radial-gradient(ellipse 75% 85% at center, black 30%, rgba(0,0,0,0.8) 50%, rgba(0,0,0,0.4) 70%, transparent 95%);
    mask-image: radial-gradient(ellipse 75% 85% at center, black 30%, rgba(0,0,0,0.8) 50%, rgba(0,0,0,0.4) 70%, transparent 95%);
  }

  .subgroups-intro {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 46;
    opacity: 0;
    pointer-events: none;
  }

  .subgroups-intro__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(10, 10, 18, 0.85) 0%, rgba(10, 10, 18, 0.7) 50%, rgba(10, 10, 18, 0.85) 100%),
      url('/images/Backgrounds/subgroup.jpg') center/cover no-repeat;
  }

  .subgroups-intro__content {
    position: absolute;
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 90%;
    max-width: 1200px;
  }

  .subgroups-intro__heading {
    font-family: 'Inter', sans-serif;
    font-size: 5.5vw;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0;
    color: #ffffff;
    text-shadow: 0 4px 40px rgba(0, 0, 0, 0.9), 0 2px 10px rgba(0, 0, 0, 0.7);
  }

  .subgroups-intro__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1.1vw;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 1.5vh;
  }

  .subgroups-intro__previews {
    display: flex;
    justify-content: center;
    gap: 2vw;
    margin-top: 5vh;
    flex-wrap: wrap;
  }

  .subgroups-intro__card {
    position: relative;
    width: 15vw;
    height: 22vh;
    border-radius: 1vw;
    overflow: hidden;
    background: #1a1a2e;
    border: 0.1vw solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 1vh 3vh rgba(0, 0, 0, 0.5);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .subgroups-intro__card:hover {
    transform: scale(1.05);
    box-shadow: 0 1.5vh 4vh rgba(0, 0, 0, 0.6);
  }

  .subgroups-intro__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .subgroups-intro__card-name {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5vh 0.8vw;
    font-family: 'Inter', sans-serif;
    font-size: 1.1vw;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.02em;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.5) 60%, transparent 100%);
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.9);
  }

  .subgroups-intro__card--bookclub .subgroups-intro__card-img {
    transform: scale(1.4);
    object-position: center center;
  }

  .subgroup {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 42;
    pointer-events: none;
    opacity: 0;
    display: block;
    padding: 5vh 4vw;
    overflow: visible;
  }

  .subgroup__left,
  .subgroup__right {
    max-width: 20.83vw;
    will-change: transform, opacity;
    overflow: visible;
    position: absolute;

    background: rgba(0, 0, 0, 0.35);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    backdrop-filter: blur(20px) saturate(180%);
    padding: 1.48vh 1.46vw;
    border-radius: 0.83vw;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      0 0.59vh 2.37vh rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .subgroup__left {
    text-align: left;
    top: 5vh;
    left: 12vw;
  }

  .subgroup__right {
    text-align: right;
    bottom: 5vh;
    right: 12vw;
  }

  .subgroup__name {
    font-family: 'Inter', sans-serif;
    font-size: 3vw;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 0 0 0.37vh;
    text-transform: uppercase;
    padding: 0.15vh 0.04vw;
  }

  .subgroup__tagline {
    font-family: 'Inter', sans-serif;
    font-size: 0.75vw;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0;
    opacity: 0.8;
  }

  .subgroup__info {
    display: flex;
    flex-direction: column;
    gap: 0.37vh;
  }

  .subgroup__label {
    display: block;
    font-size: 0.58vw;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: 0.15vh;
  }

  .subgroup__time,
  .subgroup__contact,
  .subgroup__leader {
    font-family: 'Inter', sans-serif;
    font-size: 0.83vw;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }

  .subgroup__channel {
    font-family: 'Inter', sans-serif;
    font-size: 0.625vw;
    font-weight: 500;
    margin: 0;
    opacity: 0.7;
  }

  .subgroup__desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.67vw;
    font-weight: 500;
    line-height: 1.5;
    margin: 0.37vh 0 0;
    opacity: 0.85;
  }

  .subgroup--animusic .subgroup__name {
    background: linear-gradient(135deg, #ff6ec7 0%, #00d4ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .subgroup--animusic .subgroup__tagline,
  .subgroup--animusic .subgroup__info {
    color: #ffffff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }

  .subgroup--cosplay .subgroup__name {
    background: linear-gradient(135deg, #ff9f43 0%, #ffd32a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .subgroup--cosplay .subgroup__tagline,
  .subgroup--cosplay .subgroup__info {
    color: #fff8e8;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }

  .subgroup__photo {
    position: absolute;
    z-index: 41;
    pointer-events: none;
  }
  .subgroup__photo img {
    height: 33.33vh;
    width: auto;
    object-fit: contain;
    border-radius: 0.5vw;
    box-shadow: 0 0.59vh 2.37vh rgba(0, 0, 0, 0.5);
  }
  .subgroup__photo--left {
    left: 12vw;
    bottom: 5vh;
  }
  .subgroup__photo--right {
    right: 12vw;
    top: 5vh;
  }

  .subgroup--oldanime .subgroup__name {
    color: #ffffff;
    text-shadow: 2px 2px 0 #000, -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000;
  }
  .subgroup--oldanime .subgroup__tagline,
  .subgroup--oldanime .subgroup__info {
    color: #e0e0e0;
    text-shadow: 1px 1px 0 #000;
  }

  .subgroup--bookclub .subgroup__name {
    background: linear-gradient(135deg, #e8b4f8 0%, #a855f7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .subgroup--bookclub .subgroup__tagline,
  .subgroup--bookclub .subgroup__info {
    color: #f0e0ff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }

  .subgroup--rainbow .subgroup__name {
    background: linear-gradient(135deg,
      #e74c3c 0%, #e67e22 20%, #f1c40f 40%,
      #2ecc71 60%, #3498db 80%, #9b59b6 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .subgroup--rainbow .subgroup__tagline,
  .subgroup--rainbow .subgroup__info {
    color: #ffffff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.6);
  }

  @media (max-width: 768px) {
    .subgroups-intro__heading {
      font-size: 40px;
    }

    .subgroups-intro__subtitle {
      font-size: 13px;
      margin-top: 0.75rem;
    }

    .subgroups-intro__previews {
      gap: 12px;
      margin-top: 2rem;
    }

    .subgroups-intro__card {
      width: 140px;
      height: 100px;
      border-radius: 12px;
    }

    .subgroups-intro__card-name {
      font-size: 13px;
      padding: 10px 12px;
    }

    .subgroup {
      flex-direction: column;
      justify-content: flex-start;
      padding: 15vh 1.5rem 0;
      gap: 1rem;
    }

    .subgroup__left,
    .subgroup__right {
      max-width: 100%;
      text-align: center;
      padding: 1rem 1.25rem;
      border-radius: 12px;
    }

    .subgroup__name {
      font-size: 28px;
      padding: 0.1em 0;
    }

    .subgroup__tagline {
      font-size: 11px;
    }

    .subgroup__label {
      font-size: 10px;
    }

    .subgroup__time,
    .subgroup__contact,
    .subgroup__leader {
      font-size: 14px;
    }

    .subgroup__desc {
      font-size: 12px;
    }

    .subgroup__photo img {
      height: 25vh;
      border-radius: 8px;
    }

    .subgroup__info {
      align-items: center;
    }
  }

</style>
