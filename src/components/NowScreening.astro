    transform: scale(0.95);
  }

  .meetings__anime-display {
    flex: 1;
    position: relative;
    min-height: 0;
  }

  .meetings__anime-slide {
    position: absolute;
    inset: 0;
    display: flex;
    gap: 1.33vw;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
    transform: translateX(20px);
    will-change: transform, opacity;
    backface-visibility: hidden;
    overflow: hidden;
  }

  .meetings__anime-slide--active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
    transform: translateX(0);
  }

  .meetings__anime-poster {
    flex-shrink: 0;
    width: 9.17vw;
    aspect-ratio: 2 / 3;
    border-radius: 0.5vw;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  .meetings__anime-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .meetings__anime-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .meetings__anime-date {
    font-family: 'Inter', sans-serif;
    font-size: 0.5vw;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.37vh;
  }

  .meetings__anime-title {
    font-family: 'Inter', sans-serif;
    font-size: 1.17vw;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.37vh 0;
    letter-spacing: -0.02em;
  }

  .meetings__anime-score {
    display: inline-flex;
    align-items: center;
    gap: 0.26vh;
    font-family: 'Inter', sans-serif;
    font-size: 0.625vw;
    font-weight: 600;
    color: #fbbf24;
    margin-bottom: 0.37vh;
  }

  .meetings__anime-meta {
    margin-bottom: 0.56vh;
  }

  .meetings__anime-episodes {
    display: inline-block;
    padding: 0.26vh 0.5vw;
    font-family: 'Inter', sans-serif;
    font-size: 0.5vw;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 0.25vw;
  }

  .meetings__anime-synopsis {
    font-family: 'Inter', sans-serif;
    font-size: 0.58vw;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    max-width: 16.67vw;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
  }

  .meetings__thumbnails {
    display: flex;
    justify-content: center;
    gap: 0.5vw;
    padding-bottom: 0.37vh;
  }

  .meetings__thumbnail {
    width: 2.29vw;
    aspect-ratio: 2 / 3;
    border-radius: 0.25vw;
    overflow: hidden;
    border: 2px solid transparent;
    background: rgba(255, 255, 255, 0.1);
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
    opacity: 0.5;
  }

  .meetings__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .meetings__thumbnail:hover {
    opacity: 0.8;
    transform: scale(1.05);
  }

  .meetings__thumbnail--active {
    opacity: 1;
    border-color: #ffffff;
    transform: scale(1.1);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  .meetings__location {
    display: flex;
    align-items: stretch;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.67vw;
    overflow: hidden;
  }

  .meetings__location-image {
    flex-shrink: 0;
    width: 14.58vw;
    position: relative;
    overflow: hidden;
  }

  .meetings__location-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .meetings__location-info {
    flex: 1;
    padding: 1.48vh 1.67vw;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .meetings__location-name {
    font-family: 'Inter', sans-serif;
    font-size: 1vw;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.26vh 0;
    letter-spacing: 0.01em;
  }

  .meetings__location-address {
    font-family: 'Inter', sans-serif;
    font-size: 0.67vw;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 0.93vh 0;
  }

  .meetings__location-rooms {
    display: flex;
    gap: 0.67vw;
  }

