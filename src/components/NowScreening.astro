    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.22vh;
    padding: 0.74vh 0.83vw;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 0.42vw;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .meetings__location-room-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.5vw;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .meetings__location-room-value {
    font-family: 'Inter', sans-serif;
    font-size: 0.75vw;
    font-weight: 600;
    color: #ffffff;
  }

  @media (max-width: 1000px) {
    .meetings__hero-title {
      text-align: center;
    }

    .meetings__anime-slide {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .meetings__anime-synopsis {
      max-width: 100%;
      -webkit-line-clamp: 3;
    }

    .meetings__location {
      flex-direction: column;
    }

    .meetings__location-image {
      width: 100%;
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .meetings__location-rooms {
      flex-direction: column;
    }
  }

  @media (max-width: 768px) {
    .meetings-content {
      padding: 1rem;
      padding-top: 60px;
      padding-bottom: 1rem;
    }

    .meetings__punch-image {
      height: 50vh;
    }

    .meetings__reze-image {
      height: 60vh;
    }

    .meetings__hero-title {
      font-size: 32px;
    }

    .meetings__section-title {
      font-size: 18px;
    }

    .meetings__section-subtitle {
      font-size: 11px;
    }

    .meetings__main {
      max-width: 100%;
    }

    .meetings__viewer {
      max-width: 100%;
      gap: 0.5rem;
    }

    .meetings__arrow {
      width: 40px;
      height: 40px;
    }

    .meetings__arrow svg {
      width: 20px;
      height: 20px;
    }

    .meetings__anime-poster {
      width: 100px;
      border-radius: 8px;
    }

    .meetings__anime-date {
      font-size: 10px;
    }

    .meetings__anime-title {
      font-size: 16px;
    }

    .meetings__anime-score {
      font-size: 12px;
    }

    .meetings__anime-episodes {
      font-size: 10px;
      padding: 4px 8px;
      border-radius: 4px;
    }

    .meetings__anime-synopsis {
      font-size: 12px;
      max-width: 100%;
      -webkit-line-clamp: 2;
    }

    .meetings__thumbnails {
      gap: 6px;
    }

    .meetings__thumbnail {
      width: 36px;
      border-radius: 4px;
    }

    .meetings__location {
      border-radius: 12px;
    }

    .meetings__location-image {
      display: none;
    }

    .meetings__location-info {
      padding: 1rem;
    }

    .meetings__location-name {
      font-size: 14px;
    }

    .meetings__location-address {
      font-size: 12px;
    }

    .meetings__location-room {
      padding: 0.5rem 0.75rem;
      border-radius: 8px;
    }

    .meetings__location-room-label {
      font-size: 9px;
    }

    .meetings__location-room-value {
      font-size: 12px;
    }
  }
</style>

<script>

  (async function() {
    const cells = document.querySelectorAll('.meetings__bg-cell') as NodeListOf<HTMLElement>;
    if (cells.length === 0) return;

    try {

      const [res1, res2, res3, res4] = await Promise.all([
        fetch('https://api.jikan.moe/v4/top/anime?limit=25&page=1'),
        fetch('https://api.jikan.moe/v4/top/anime?limit=25&page=2'),
        fetch('https://api.jikan.moe/v4/top/anime?limit=25&page=3'),
        fetch('https://api.jikan.moe/v4/top/anime?limit=25&page=4')
      ]);
      const [json1, json2, json3, json4] = await Promise.all([
        res1.json(), res2.json(), res3.json(), res4.json()
      ]);

      const extractImages = (json: any) => json.data
        ?.map((a: any) => a.images?.jpg?.large_image_url || a.images?.jpg?.image_url)
        .filter(Boolean) || [];

      const allImages = [
        ...extractImages(json1), ...extractImages(json2),
        ...extractImages(json3), ...extractImages(json4)
      ];
      const uniqueImages = [...new Set(allImages)];
      if (uniqueImages.length === 0) return;

      const shuffled = [...uniqueImages].sort(() => Math.random() - 0.5);

      cells.forEach((cell, i) => {
        cell.style.backgroundImage = `url(${shuffled[i % shuffled.length]})`;
      });
    } catch (e) {
      console.error('Failed to load anime background images:', e);
    }
  })();

  (function() {
    const slides = document.querySelectorAll('.meetings__anime-slide') as NodeListOf<HTMLElement>;
    const thumbnails = document.querySelectorAll('.meetings__thumbnail') as NodeListOf<HTMLElement>;
    const leftArrow = document.querySelector('[data-arrow-left]') as HTMLElement;
    const rightArrow = document.querySelector('[data-arrow-right]') as HTMLElement;

    if (slides.length === 0) return;

    let currentIndex = 0;
    const totalSlides = slides.length;

    function goToSlide(index: number) {

      if (index < 0) index = totalSlides - 1;
      if (index >= totalSlides) index = 0;

      slides.forEach((slide, i) => {
        slide.classList.remove('meetings__anime-slide--active');
        if (i === index) {
          slide.classList.add('meetings__anime-slide--active');
        }
      });

      thumbnails.forEach((thumb, i) => {
        thumb.classList.remove('meetings__thumbnail--active');
        if (i === index) {
          thumb.classList.add('meetings__thumbnail--active');
        }
      });

      currentIndex = index;
    }

    if (leftArrow) {
      leftArrow.addEventListener('click', () => {
        goToSlide(currentIndex - 1);
      });
    }

    if (rightArrow) {
      rightArrow.addEventListener('click', () => {
        goToSlide(currentIndex + 1);
      });
    }

    thumbnails.forEach((thumb, i) => {
      thumb.addEventListener('click', () => {
        goToSlide(i);
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        goToSlide(currentIndex - 1);
      } else if (e.key === 'ArrowRight') {
        goToSlide(currentIndex + 1);
      }
    });
  })();
</script>
