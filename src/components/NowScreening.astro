---
import screeningsData from '../data/screenings.json';
import { generateScreeningDates, formatScreeningDate } from '../utils/anime';

const { screenings, startDate, location } = screeningsData;
const dates = generateScreeningDates(startDate, screenings.length);

const schedule = screenings.map((screening, index) => ({
  ...screening,
  date: dates[index],
  formattedDate: formatScreeningDate(dates[index]),
}));

---

<div class="meetings__bg-collage" data-meetings-bg>
  {Array.from({ length: 200 }).map((_, i) => (
    <div class="meetings__bg-cell" data-cell={i}></div>
  ))}
</div>

<div class="meetings-content" data-meetings-content>
  <div class="meetings__punch">
    <img src="/images/Characters/punch.webp" alt="Punch mascot" class="meetings__punch-image" />
  </div>

  <div class="meetings__reze">
    <img src="/images/Characters/Reze.webp" alt="Reze" class="meetings__reze-image" />
  </div>

  <div class="meetings__main">
    <h1 class="meetings__hero-title">{screeningsData.meetingsHeading}</h1>

    <div class="meetings__screenings-section">
      <div class="meetings__section-header">
        <h2 class="meetings__section-title">{screeningsData.screeningsTitle}</h2>
        <p class="meetings__section-subtitle">{screeningsData.screeningsSubtitle}</p>
      </div>

      <div class="meetings__viewer" data-anime-viewer>
        <button class="meetings__arrow meetings__arrow--left" data-arrow-left aria-label="Previous anime">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <div class="meetings__anime-display">
          {schedule.map((anime, index) => (
            <div
              class={`meetings__anime-slide ${index === 0 ? 'meetings__anime-slide--active' : ''}`}
              data-slide={index}
              data-image={anime.image}
              data-title={anime.title}
              data-synopsis={anime.synopsis}
              data-episodes={anime.episodes || '?'}
              data-date={anime.formattedDate}
              data-score={anime.score || ''}
            >
              <div class="meetings__anime-poster">
                <img src={anime.image} alt={anime.title} loading="lazy" />
              </div>
              <div class="meetings__anime-details">
                <span class="meetings__anime-date">{anime.formattedDate}</span>
                <h3 class="meetings__anime-title">{anime.title}</h3>
                {anime.score && (
                  <span class="meetings__anime-score">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                    {anime.score}
                  </span>
                )}
                <div class="meetings__anime-meta">
                  <span class="meetings__anime-episodes">{anime.episodes || '?'} Episodes</span>
                </div>
                <p class="meetings__anime-synopsis">
                  {anime.synopsis.length > 280
                    ? anime.synopsis.substring(0, 280) + '...'
                    : anime.synopsis}
                </p>
              </div>
            </div>
          ))}
        </div>

        <button class="meetings__arrow meetings__arrow--right" data-arrow-right aria-label="Next anime">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>

      <div class="meetings__thumbnails" data-thumbnails>
        {schedule.map((anime, index) => (
          <button
            class={`meetings__thumbnail ${index === 0 ? 'meetings__thumbnail--active' : ''}`}
            data-thumbnail={index}
            aria-label={`Go to ${anime.title}`}
          >
            <img src={anime.image} alt={anime.title} loading="lazy" />
          </button>
        ))}
      </div>
    </div>

    <div class="meetings__location-section">
      <div class="meetings__location">
        <div class="meetings__location-image">
          <img src="/images/Photos/sociology.webp" alt="Parren J Mitchell Art-Sociology Building" />
        </div>
        <div class="meetings__location-info">
          <h3 class="meetings__location-name">{location.building}</h3>
          <p class="meetings__location-address">{location.address}</p>
          <div class="meetings__location-rooms">
            {location.rooms.map((room) => (
              <div class="meetings__location-room">
                <span class="meetings__location-room-label">{room.label}</span>
                <span class="meetings__location-room-value">{room.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      </div>
    </div>
  </div>
</div>

<style>

  .meetings-content {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100vh;
    padding: 1.25vw;
    padding-top: 7.41vh;
    padding-bottom: 1.48vh;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    overflow: hidden;
    z-index: 30;
    display: flex;
    flex-direction: column;
    will-change: transform, opacity;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .meetings__bg-collage {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    display: grid;

    grid-template-columns: repeat(auto-fill, minmax(5vw, 1fr));
    gap: 0;
    pointer-events: none;
    z-index: 25;
    overflow: hidden;
    visibility: visible;

    background-color: #1a1a1a;
    will-change: transform;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .meetings__bg-collage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: rgba(10, 10, 10, 0.7);
    pointer-events: none;
    z-index: 2;
  }

  .meetings__bg-collage::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 65% 65% at center,
      transparent 0%,
      transparent 35%,
      rgba(10, 10, 10, 0.1) 45%,
      rgba(10, 10, 10, 0.25) 55%,
      rgba(10, 10, 10, 0.45) 65%,
      rgba(10, 10, 10, 0.7) 80%,
      rgba(10, 10, 10, 0.9) 90%,
      #0a0a0a 100%);
    pointer-events: none;
    z-index: 3;
  }

  .meetings__bg-cell {

    position: relative;
    z-index: 1;
    width: calc(100% + 0.083vw);
    aspect-ratio: 2 / 3;
    background-color: #1a1a1a;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;

    margin-right: -0.083vw;
    margin-bottom: -0.083vw;
  }

  .meetings__punch {
    position: absolute;
    top: 0;
    right: 5vw;
    z-index: 2;
    pointer-events: none;
  }

  .meetings__punch-image {
    height: 75vh;
    width: auto;
    object-fit: contain;
    object-position: top;
    opacity: 0.85;
  }

  .meetings__reze {
    position: absolute;
    bottom: 0;
    left: 5vw;
    z-index: 2;
    pointer-events: none;
  }

  .meetings__reze-image {
    height: 85vh;
    width: auto;
    object-fit: contain;
    object-position: bottom;
    opacity: 0.85;
  }

  .meetings__hero-title {
    font-family: 'Inter', sans-serif;
    font-size: 4.17vw;
    font-weight: 800;
    color: #ffffff;
    text-align: left;
    margin: 0;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 0.9;
    text-shadow: 0 4px 40px rgba(0, 0, 0, 0.9), 0 2px 10px rgba(0, 0, 0, 0.7);
  }

  .meetings__section-header {
    margin-bottom: 0.74vh;
    text-align: center;
  }

  .meetings__section-title {
    font-family: 'Inter', sans-serif;
    font-size: 1.17vw;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.19vh 0;
    letter-spacing: -0.02em;
  }

  .meetings__section-title--small {
    font-size: 2vw;
    margin-bottom: 1.11vh;
    text-align: center;
  }

  .meetings__section-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.58vw;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
