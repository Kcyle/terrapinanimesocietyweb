---
import { HUNT_PROMPTS } from '../../data/hunt-prompts';
import QRCode from 'qrcode';

const baseUrl = 'https://tas.umd.edu';

const qrCodes: { id: number; title: string; svg: string; url: string }[] = [];

for (const prompt of HUNT_PROMPTS) {
  const url = `${baseUrl}/hunt/${prompt.id}/`;
  const svg = await QRCode.toString(url, {
    type: 'svg',
    color: { dark: '#ffffff', light: '#00000000' },
    margin: 1,
    width: 200,
  });
  qrCodes.push({ id: prompt.id, title: prompt.title, svg, url });
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QR Codes - Scavenger Hunt</title>
  <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: #0a0a0a;
      color: #fff;
      padding: 2rem;
    }

    h1 {
      font-family: 'Bangers', cursive;
      font-size: 2rem;
      text-align: center;
      color: #fbbf24;
      margin-bottom: 0.5rem;
    }
    .subtitle {
      text-align: center;
      color: #666;
      font-size: 0.85rem;
      margin-bottom: 2rem;
    }

    .qr-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .qr-card {
      background: #141414;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 1.5rem;
      text-align: center;
    }

    .qr-card__number {
      font-family: 'Bangers', cursive;
      font-size: 1.3rem;
      color: #fbbf24;
      margin-bottom: 0.25rem;
    }

    .qr-card__title {
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .qr-card__svg {
      width: 180px;
      height: 180px;
      margin: 0 auto 0.75rem;
    }
    .qr-card__svg :global(svg) {
      width: 100%;
      height: 100%;
    }

    .qr-card__url {
      font-size: 0.65rem;
      color: #555;
      word-break: break-all;
    }

    .print-note {
      text-align: center;
      margin-top: 2rem;
      color: #555;
      font-size: 0.8rem;
    }

    .print-btn {
      display: block;
      margin: 1rem auto;
      padding: 0.7rem 2rem;
      background: linear-gradient(135deg, #ff6b6b, #fbbf24);
      color: #0a0a0a;
      border: none;
      border-radius: 10px;
      font-family: inherit;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
    }

    @media print {
      body { background: #fff; color: #000; padding: 0.5rem; }
      .print-btn, .print-note { display: none; }
      .qr-card {
        background: #fff;
        border: 2px solid #000;
        break-inside: avoid;
      }
      .qr-card__number { color: #000; }
      .qr-card__url { color: #333; }
      h1 { color: #000; }
      .subtitle { color: #666; }
    }
  </style>
</head>
<body>
  <h1>Scavenger Hunt QR Codes</h1>
  <p class="subtitle">Print these and scatter them around the building</p>

  <button class="print-btn" onclick="window.print()">Print QR Codes</button>

  <div class="qr-grid">
    {qrCodes.map((qr) => (
      <div class="qr-card">
        <div class="qr-card__number">#{qr.id}</div>
        <div class="qr-card__title">{qr.title}</div>
        <div class="qr-card__svg" set:html={qr.svg} />
        <div class="qr-card__url">{qr.url}</div>
      </div>
    ))}
  </div>

  <p class="print-note">Tip: Cut out each QR code card and tape them in different locations</p>
</body>
</html>
