---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/navigation/Header.astro';

---

<BaseLayout title="Maid Cafe - Terrapin Anime Society">
  <Fragment slot="head">
    <meta name="description" content="TAS Maid Cafe - April 5th, 2026. Reserve your spot for an unforgettable experience at the Colony Ballroom, Stamp Student Union." />
    <style>html, body { overflow: hidden; height: 100vh; height: 100dvh; }</style>
  </Fragment>
  <Header />

  <main class="mc">
    <div class="mc__bg"></div>

    <!-- Left: Event Info -->
    <div class="mc__info">
      <h1 class="mc__title">Maid&nbsp;Cafe</h1>
      <p class="mc__date">April 5, 2026</p>
      <p class="mc__time">2:00 to 5:00 PM</p>
    </div>

    <img src="/images/Characters/maids.webp" alt="Maid Cafe Characters" class="mc__maids" />

    <!-- Right: Steps -->
    <div class="mc__form-area">

      <!-- ========== STEP 1: Google Sign In ========== -->
      <div id="step-email" class="mc-step">
        <h2 class="mc-form__title">Welcome</h2>
        <p class="mc-step__sub">Sign in with your TerpMail account.</p>
        <p class="mc-step__restrict">Only @terpmail.umd.edu and @umd.edu accounts are accepted.</p>
        <div class="mc-google-signin">
          <button type="button" id="google-signin-btn" class="mc-google-btn">
            <svg viewBox="0 0 24 24" width="20" height="20">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Sign in with Google
          </button>
        </div>
        <p id="gate-email-error" class="mc-step__error" style="display:none"></p>
        <p class="mc-step__guest-note">If you are a non UMD student or alumni, please either have a current UMD student RSVP and add you to their reservation, or contact us directly at <strong>terrapinanimesociety@gmail.com</strong> or on our <a href="https://discord.com/invite/GJXS7aM7YQ" target="_blank" rel="noopener" style="color:#FFA500;text-decoration:underline;">Discord server</a> (<strong>@kcyle_</strong>).</p>
      </div>

      <!-- ========== VIEW RESERVATION ========== -->
      <div id="step-view-order" class="mc-step" style="display:none">
        <h2 class="mc-form__title">My Reservation</h2>
        <div id="view-order-content"></div>
        <div class="mc-confirm-actions" style="margin-top:1rem;">
          <button type="button" id="view-order-back" class="mc-btn-secondary">Back</button>
        </div>
      </div>

      <!-- ========== STEP 2: Event Info Agreement ========== -->
      <div id="step-info" class="mc-step" style="display:none">
        <h2 class="mc-form__title">Event Information</h2>
        <div class="mc-event-info">
          <div class="mc-event-info__header">
            <p><strong>Sunday, April 5th, 2026</strong> | 2:00 to 5:00 PM</p>
            <p>Colony Ballroom, Stamp Student Union, 3972 Campus Dr, College Park, MD 20742</p>
            <p class="mc-event-info__muted">You do not have to stay the entire time, but please arrive on time!</p>
          </div>

          <div class="mc-event-info__section">
            <p>To secure your spot, send <strong>$15</strong> via <a href="https://venmo.com/u/Terrapin-Anime-Society" target="_blank" rel="noopener" style="color:#FFB6C1;text-decoration:underline;">Venmo</a> with <strong>"(Your Name) for Maid Cafe"</strong> to <strong>@Terrapin-Anime-Society</strong>.</p>
            <p class="mc-event-info__muted">Door tickets may be available if space allows, but preordering is recommended.</p>
          </div>

          <h3 class="mc-event-info__title">Schedule (approximate)</h3>

          <div class="mc-event-info__schedule">
            <div class="mc-event-info__slot">
              <strong>2:00 to 3:00 PM</strong>
              <ul>
                <li>Check in, seating, and dining with your maid or butler</li>
                <li>Full course meal (main dish, dessert, side, and drink including strawberry shortcake and mini French pastries)</li>
                <li>Table games such as Beyblades, cards, board games, and drawing</li>
              </ul>
            </div>
            <div class="mc-event-info__slot">
              <strong>3:00 to 4:00 PM</strong>
              <ul>
                <li>Group activities and events with all guests, maids, and butlers</li>
                <li>Karaoke, musical chairs, and other large scale group games</li>
              </ul>
            </div>
            <div class="mc-event-info__slot">
              <strong>4:00 to 5:00 PM</strong>
              <ul>
                <li>Performances by our maids</li>
              </ul>
            </div>
          </div>

          <div class="mc-event-info__important">
            <h3 class="mc-event-info__title">Important</h3>
            <ul>
              <li>Your reservation is not confirmed until payment is received via Venmo.</li>
              <li>Do not promote this event outside of the UMD community.</li>
            </ul>
          </div>

          <div class="mc-event-info__footer">
            <a href="https://youtube.com/shorts/ReyEl3XILK8" target="_blank" rel="noopener" class="mc__directions">How to find the Colony Ballroom</a>
            <p>Questions: <strong>terrapinanimesociety@gmail.com</strong> | <a href="https://discord.com/invite/GJXS7aM7YQ" target="_blank" rel="noopener" style="color:#FF69B4;text-decoration:underline;">Discord Server</a> | <strong>@kcyle_</strong></p>
          </div>
        </div>
        <button type="button" id="gate-agree-btn" class="mc-submit">I Agree, Continue to Reservation</button>
      </div>

      <!-- ========== STEP 3: Reservation Form ========== -->
      <form id="maidcafe-form" class="mc-form" autocomplete="off" novalidate style="display:none">
        <h2 class="mc-form__title">Reserve Your Spot</h2>
        <p class="mc-form__sub">$15 per person via <a href="https://venmo.com/u/Terrapin-Anime-Society" target="_blank" rel="noopener" style="color:#FFB6C1;text-decoration:underline;">Venmo</a> to <strong>@Terrapin-Anime-Society</strong></p>

        <div class="mc-field">
          <label for="full-name" class="mc-label">Full Name <span class="mc-req">*</span></label>
          <input type="text" id="full-name" name="full_name" required class="mc-input" placeholder="Must match your Venmo display name" />
        </div>

        <div class="mc-field">
          <label for="email" class="mc-label">Email <span class="mc-req">*</span></label>
          <input type="email" id="email" name="email" required class="mc-input" placeholder="you@email.com" />
        </div>

        <div class="mc-field">
          <label class="mc-label">Preferred Contact Method <span class="mc-req">*</span></label>
          <div class="mc-radio-row">
            <label class="mc-chip"><input type="radio" name="contact_method" value="email" required /><span>Email</span></label>
            <label class="mc-chip"><input type="radio" name="contact_method" value="discord" /><span>Discord</span></label>
            <label class="mc-chip"><input type="radio" name="contact_method" value="phone" /><span>Phone</span></label>
          </div>
          <input type="text" id="contact-value" name="contact_value" class="mc-input mc-input--contact" style="display:none" />
        </div>

        <div class="mc-row">
          <div class="mc-field mc-field--half">
            <label for="num-guests" class="mc-label">Number of Guests in Party <span class="mc-req">*</span></label>
            <select id="num-guests" name="num_guests" required class="mc-input mc-select">
              <option value="1">1 (just me)</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5">5</option>
              <option value="6">6</option>
            </select>
          </div>
          <div class="mc-field mc-field--half">
            <label class="mc-label">Preferred Maid or Butler</label>
            <select id="staff-select" name="preferred_staff_name" class="mc-input mc-select">
              <option value="">No preference</option>
              <optgroup label="Maids (Solo)">
                <option value="Ramin">Ramin</option>
                <option value="Bakadere">Ryn (Bakadere)</option>
                <option value="Jeremiah">Jeremiah</option>
                <option value="Her Highness">Sarah (Her Highness)</option>
                <option value="Bryan">Bryan</option>
                <option value="Nerd Tsundere">Zhe (Nerd Tsundere)</option>
                <option value="Amaya">Amaya</option>
                <option value="Mesugaki">Julian (Mesugaki)</option>
                <option value="Moe/Kawaii">Natalie (Moe/Kawaii)</option>
                <option value="The Sweet Sarcastic Type">Kiara (The Sweet Sarcastic Type)</option>
              </optgroup>
              <optgroup label="Maids (Paired)">
                <option value="Joyna + Nina">Joyna + Nina</option>
                <option value="Ella + Cecile (Deredere)">Ella + Cecile (Deredere)</option>
              </optgroup>
              <optgroup label="Butlers (Solo)">
                <option value="Tigger">Aahil (Tigger)</option>
                <option value="Professional Degrader">Zayan (Professional Degrader)</option>
                <option value="The Chalant Butler">Gabriel (The Chalant Butler)</option>
              </optgroup>
              <optgroup label="Maid or Butler (Either Role)">
                <option value="Noah Cao">Noah Cao</option>
                <option value="Noah Martin">Noah Martin (Nonchalant Tsundere)</option>
                <option value="Adam">Adam</option>
                <option value="Kyle Duong">Kyle Duong</option>
                <option value="The Servant">Justin (The Servant)</option>
                <option value="Cowboy Butler">Nikolai (Cowboy Butler)</option>
              </optgroup>
              <optgroup label="Maid and Butler (Paired)">
                <option value="Joely + Zayan">Joely + Zayan</option>
                <option value="Noah Martin + Gabriel">Noah Martin + Gabriel</option>
                <option value="Adam + Nikolai">Adam + Nikolai</option>
              </optgroup>
            </select>
            <input type="hidden" id="preferred-staff-id" name="preferred_staff_id" value="" />
          </div>
        </div>

        <!-- Dynamic guest info (appears when guests > 1) -->
        <div id="guest-info-section" style="display:none">
          <label class="mc-label">Additional Guest Information <span class="mc-req">*</span></label>
          <p class="mc-hint">Please provide the name and affiliation of each additional guest.</p>
          <div id="guest-info-fields" class="mc-guest-fields"></div>
        </div>

        <div class="mc-field">
          <label for="allergies" class="mc-label">Allergies or Dietary Restrictions <span class="mc-req">*</span></label>
          <input type="text" id="allergies" name="allergies" required class="mc-input" placeholder="Type None if not applicable" />
        </div>

        <!-- Add-on Package -->
        <div class="mc-addon">
          <label class="mc-addon__toggle">
            <input type="checkbox" id="addon-package" name="has_addon_package" />
            <div class="mc-addon__card">
              <div class="mc-addon__header">
                <span class="mc-addon__title">VIP Experience Package</span>
                <span class="mc-addon__price">+$10</span>
              </div>
              <ul class="mc-addon__list">
                <li>Sparkling non alcoholic cocktail</li>
                <li>Birthday cake celebration with singing</li>
                <li>Pictures with the maids</li>
                <li>Priority front row seating (Tables 2 and 3)</li>
                <li>Possible advantage in group activities, games, and raffles</li>
              </ul>
              <p class="mc-addon__party-note" id="addon-party-note" style="display:none">
                Your entire party receives priority front row seating. The package includes one birthday candle cake celebration and one sparkling cocktail bottle for the group. Everyone in your party is welcome to take pictures with the maids.
              </p>
            </div>
          </label>
        </div>

        <!-- Seat Picker -->
        <div class="mc-field">
          <label class="mc-label">Choose Your Seats <span class="mc-req">*</span></label>
          <p class="mc-hint">All seats must be at the same table. Click to select.</p>
          <div class="mc-seating-legend">
            <span class="mc-legend-item"><span class="mc-legend-dot mc-legend-dot--available"></span> Available</span>
            <span class="mc-legend-item"><span class="mc-legend-dot mc-legend-dot--selected"></span> Selected</span>
            <span class="mc-legend-item"><span class="mc-legend-dot mc-legend-dot--taken"></span> Taken</span>
            <span class="mc-legend-item"><span class="mc-legend-dot mc-legend-dot--vip"></span> VIP (Tables 2 and 3)</span>
          </div>
          <div id="seating-diagram" class="mc-seating"></div>
          <p id="seat-selection-summary" class="mc-seat-summary"></p>
        </div>

        <!-- Price Summary -->
        <div class="mc-price" id="price-summary">
          <div class="mc-price__row">
            <span>Base ticket</span>
            <span id="price-base">$15 x 1 = $15</span>
          </div>
          <div class="mc-price__row mc-price__row--addon" id="price-addon-row" style="display:none">
            <span>VIP Package</span>
            <span>+$10</span>
          </div>
          <div class="mc-price__total">
            <span>Total</span>
            <span id="price-total">$15</span>
          </div>
        </div>

        <button type="submit" id="submit-btn" class="mc-submit">Continue to Checkout</button>
      </form>
    </div>

    <!-- ============ TERMS MODAL ============ -->
    <div id="terms-modal" class="mc-modal" style="display:none">
      <div class="mc-modal__backdrop"></div>
      <div class="mc-modal__content">
        <h2>Event Information</h2>
        <div class="mc-terms-body">
          <p><strong>Sunday, April 5th, 2026</strong> | 2:00 to 5:00 PM</p>
          <p>Colony Ballroom, Stamp Student Union, 3972 Campus Dr, College Park, MD 20742</p>
          <p>You do not have to stay the entire time, but please arrive on time.</p>
          <h3>Schedule</h3>
          <ul>
            <li><strong>2:00 to 3:00 PM</strong> — Check in, seating, and dining with your maid or butler. Full course meal (main dish, dessert, side, and drink including strawberry shortcake and mini French pastries). Table games like Beyblades, cards, board games, and drawing.</li>
            <li><strong>3:00 to 4:00 PM</strong> — Group activities and events with all guests, maids, and butlers. Expect karaoke, musical chairs, and other large scale group games.</li>
            <li><strong>4:00 to 5:00 PM</strong> — Performances by our maids.</li>
          </ul>
          <h3>Important</h3>
          <ul>
            <li>Your reservation is not confirmed until payment is received via Venmo.</li>
            <li>Do not promote this event outside of the UMD community.</li>
          </ul>
          <p><a href="https://youtube.com/shorts/ReyEl3XILK8" target="_blank" rel="noopener" style="color:#FF69B4;text-decoration:underline;">How to find the Colony Ballroom from the Stamp front pillar entrance</a></p>
          <p>Questions: <strong>terrapinanimesociety@gmail.com</strong> | <a href="https://discord.com/invite/GJXS7aM7YQ" target="_blank" rel="noopener" style="color:#FF69B4;text-decoration:underline;">Discord Server</a> | <strong>@kcyle_</strong></p>
        </div>
        <button type="button" id="terms-close" class="mc-submit">Got it</button>
      </div>
    </div>

    <!-- ============ CHECKOUT: All-in-one confirmation ============ -->
    <div id="confirm-modal" class="mc-modal" style="display:none">
      <div class="mc-modal__backdrop"></div>
      <div class="mc-modal__content mc-modal__content--checkout">
        <h2>Before You Submit</h2>

        <!-- Section 1: Logistics Review -->
        <div class="mc-checkout-section">
          <h3 class="mc-checkout-section__title">Event Logistics</h3>
          <p class="mc-checkout-section__text">Make sure you have read and understand all event details, schedule, location, and policies.</p>
          <button type="button" id="checkout-view-info" class="mc-terms-link" style="font-size:0.9rem;">Review Event Information</button>
          <div id="checkout-event-info" class="mc-checkout-event-info" style="display:none">
            <p><strong>Sunday, April 5th, 2026</strong> | 2:00 to 5:00 PM</p>
            <p>Colony Ballroom, Stamp Student Union, 3972 Campus Dr, College Park, MD 20742</p>
            <p style="color:rgba(255,255,255,0.4);font-style:italic;">You do not have to stay the entire time, but please arrive on time!</p>
            <h4>Schedule</h4>
            <ul>
              <li><strong>2:00 to 3:00 PM</strong> Check in, dining, table games</li>
              <li><strong>3:00 to 4:00 PM</strong> Group activities, karaoke, games</li>
              <li><strong>4:00 to 5:00 PM</strong> Performances by maids</li>
            </ul>
            <h4>Important</h4>
            <ul>
              <li>Reservation not confirmed until Venmo payment received.</li>
              <li>Do not promote outside the UMD community.</li>
            </ul>
          </div>
        </div>

        <!-- Section 2: Order Summary -->
        <div class="mc-checkout-section">
          <h3 class="mc-checkout-section__title">Your Reservation</h3>
          <div id="confirm-summary" class="mc-confirm-summary"></div>
        </div>

        <!-- Section 3: Venmo Payment -->
        <div class="mc-checkout-section">
          <h3 class="mc-checkout-section__title">Payment</h3>
          <p class="mc-checkout-venmo__amount">Amount Due: <strong id="checkout-venmo-amount">$15</strong></p>
          <p class="mc-checkout-section__text">Send your payment via Venmo before confirming.</p>
          <div class="mc-checkout-venmo__box">
            <p><strong>Venmo:</strong> <a href="https://venmo.com/u/Terrapin-Anime-Society" target="_blank" rel="noopener" style="color:#FFB6C1;text-decoration:underline;">@Terrapin-Anime-Society</a></p>
            <p><strong>Note:</strong> "(Your Name) for Maid Cafe"</p>
          </div>
        </div>

        <!-- Section 4: Refund Policy -->
        <div class="mc-checkout-venmo__warning">
          <strong>No Refunds Policy:</strong> All sales are final. Refunds will only be issued under special circumstances with a valid reason. Contact terrapinanimesociety@gmail.com or @kcyle_ on <a href="https://discord.com/invite/GJXS7aM7YQ" target="_blank" rel="noopener" style="color:#FFA500;text-decoration:underline;">Discord</a> to request one.
        </div>

        <div class="mc-confirm-actions">
          <button type="button" id="confirm-back" class="mc-btn-secondary">Go Back</button>
          <button type="button" id="confirm-submit" class="mc-submit">I Have Paid and Confirm My Reservation</button>
        </div>
      </div>
    </div>

    <!-- ============ SUCCESS MODAL ============ -->
    <div id="success-modal" class="mc-modal" style="display:none">
      <div class="mc-modal__backdrop"></div>
      <div class="mc-modal__content">
        <h2>Reservation Submitted!</h2>
        <div class="mc-modal__order">
          <p>Your Order ID</p>
          <span id="modal-order-id" class="mc-modal__id"></span>
        </div>
        <div class="mc-modal__payment">
          <p>Make sure you have sent <strong id="modal-total">$15</strong> via <a href="https://venmo.com/u/Terrapin-Anime-Society" target="_blank" rel="noopener" style="color:#FFB6C1;text-decoration:underline;">Venmo</a> to <strong>@Terrapin-Anime-Society</strong></p>
          <p>Venmo note: <strong>"(Your Name) for Maid Cafe"</strong></p>
          <p class="mc-modal__warn">Your reservation is not confirmed until we verify your Venmo payment. Unpaid reservations may be released.</p>
        </div>
        <button type="button" id="modal-close" class="mc-submit">Done</button>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase';
  import gsap from 'gsap';
  import { initMenuAnimations } from '../animations/menu';

  /* ========== GATE STEPS ========== */
  let verifiedEmail = '';
  let verifiedName = '';


  // Google sign-in via Supabase Auth
  document.getElementById('google-signin-btn')!.addEventListener('click', async () => {
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: window.location.origin + window.location.pathname,
      }
    });
    if (error) {
      document.getElementById('gate-email-error')!.textContent = 'Sign in failed: ' + error.message;
      document.getElementById('gate-email-error')!.style.display = 'block';
    }
  });


  // Check for existing reservation
  async function checkExistingReservation(email: string): Promise<boolean> {
    try {
      const { data } = await supabase
        .from('maidcafe_reservations')
        .select('*')
        .eq('email', email)
        .neq('payment_status', 'cancelled')
        .limit(1);
      if (data && data.length > 0) {
        renderViewOrder(data[0]);
        return true;
      }
    } catch (e) {
      console.warn('Could not check reservation:', e);
    }
    return false;
  }

  function renderViewOrder(r: any) {
    const seats = r.selected_seats ? r.selected_seats.map((s: any) => `Seat ${s.seat_number}`).join(', ') : '';
    const statusClass = r.payment_status === 'confirmed' ? 'mc-view-status--confirmed' : r.payment_status === 'cancelled' ? 'mc-view-status--cancelled' : 'mc-view-status--pending';
    const guests = r.additional_guests ? r.additional_guests.map((g: any, i: number) =>
      `<div class="mc-view-row"><span>Guest ${i + 2}</span><strong>${g.name} (${g.affiliation})</strong></div>`
    ).join('') : '';

    document.getElementById('view-order-content')!.innerHTML = `
      <div class="mc-view-card">
        <div class="mc-view-header">
          <div>
            <span class="mc-view-order-id">${r.order_id}</span>
            <span class="mc-view-status ${statusClass}">${r.payment_status}</span>
          </div>
        </div>
        <div class="mc-view-rows">
          <div class="mc-view-row"><span>Name</span><strong>${r.full_name}</strong></div>
          <div class="mc-view-row"><span>Email</span><strong>${r.email}</strong></div>
          <div class="mc-view-row"><span>Party Size</span><strong>${r.num_guests}</strong></div>
          ${guests}
          <div class="mc-view-row"><span>Table</span><strong>${r.table_number || 'Not assigned'}</strong></div>
          <div class="mc-view-row"><span>Seats</span><strong>${seats || 'None'}</strong></div>
          ${r.preferred_staff_name ? `<div class="mc-view-row"><span>Preferred Staff</span><strong>${r.preferred_staff_name}</strong></div>` : ''}
          <div class="mc-view-row"><span>Package</span><strong>${r.has_addon_package ? 'VIP Experience' : 'Standard'}</strong></div>
          ${r.allergies ? `<div class="mc-view-row"><span>Allergies</span><strong>${r.allergies}</strong></div>` : ''}
          <div class="mc-view-row"><span>Total Paid</span><strong>$${r.total_price}</strong></div>
          <div class="mc-view-row"><span>Reserved</span><strong>${new Date(r.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</strong></div>
        </div>
      </div>
      <div class="mc-view-venmo">
        <p><strong>Venmo:</strong> Send <strong>$${r.total_price}</strong> via <a href="https://venmo.com/u/Terrapin-Anime-Society" target="_blank" rel="noopener" style="color:#FFB6C1;text-decoration:underline;">Venmo</a> to <strong>@Terrapin-Anime-Society</strong></p>
        <p>Note: <strong>"${r.full_name} for Maid Cafe"</strong></p>
      </div>
      <p class="mc-view-note">This reservation cannot be edited. For questions or changes, contact <strong>terrapinanimesociety@gmail.com</strong> or <strong>@kcyle_</strong> on <a href="https://discord.com/invite/GJXS7aM7YQ" target="_blank" rel="noopener" style="color:#FF69B4;text-decoration:underline;">Discord</a>.</p>
    `;
  }

  // View order back button
  document.getElementById('view-order-back')!.addEventListener('click', () => {
    document.getElementById('step-view-order')!.style.display = 'none';
    document.getElementById('step-email')!.style.display = 'flex';
    document.querySelector('.mc__form-area')?.scrollTo(0, 0);
  });

  // Check for Supabase auth session on page load (after Google redirect)
  (async function checkAuthSession() {
    const { data: { session } } = await supabase.auth.getSession();
    if (window.location.hash || window.location.href.endsWith('#')) {
      history.replaceState(null, '', window.location.pathname);
    }
    if (session?.user) {
      const email = session.user.email?.toLowerCase() || '';
      const name = session.user.user_metadata?.full_name || session.user.user_metadata?.name || '';
      if (email.endsWith('@umd.edu') || email.endsWith('@terpmail.umd.edu')) {
        verifiedEmail = email;
        verifiedName = name;
        document.getElementById('step-email')!.style.display = 'none';
        const hasReservation = await checkExistingReservation(email);
        if (hasReservation) {
          document.getElementById('step-view-order')!.style.display = 'flex';
        } else {
          document.getElementById('step-info')!.style.display = 'flex';
        }
      } else if (email) {
        await supabase.auth.signOut();
        document.getElementById('gate-email-error')!.textContent = 'Only @terpmail.umd.edu and @umd.edu accounts are accepted.';
        document.getElementById('gate-email-error')!.style.display = 'block';
      }
    }
  })();

  document.getElementById('gate-agree-btn')!.addEventListener('click', () => {
    document.getElementById('step-info')!.style.display = 'none';
    const form = document.getElementById('maidcafe-form') as HTMLFormElement;
    form.style.display = 'flex';
    document.querySelector('.mc__form-area')?.scrollTo(0, 0);
    // Init custom dropdowns now that form is visible
    setTimeout(() => initCustomDropdowns(), 100);
    // Pre-fill fields from Google profile
    const emailField = document.getElementById('email') as HTMLInputElement;
    const nameField = document.getElementById('full-name') as HTMLInputElement;
    if (emailField) {
      emailField.value = verifiedEmail;
      emailField.readOnly = true;
    }
    if (nameField && verifiedName) {
      nameField.value = verifiedName;
    }
  });

  /* ========== CONSTANTS ========== */
  const BASE_PRICE = 15;
  const ADDON_PRICE = 10;
  const VIP_TABLES = [2, 3];

  const TABLE_POSITIONS = [
    // Row 1 (closest to stage) - VIP tables
    { id: 1,  cx: 85,  cy: 150 },
    { id: 2,  cx: 250, cy: 150 },
    { id: 3,  cx: 460, cy: 150 },
    { id: 4,  cx: 625, cy: 150 },
    // Row 2
    { id: 5,  cx: 85,  cy: 320 },
    { id: 6,  cx: 250, cy: 320 },
    { id: 7,  cx: 460, cy: 320 },
    { id: 8,  cx: 625, cy: 320 },
    // Row 3
    { id: 9,  cx: 85,  cy: 490 },
    { id: 10, cx: 250, cy: 490 },
    { id: 11, cx: 460, cy: 490 },
    { id: 12, cx: 625, cy: 490 },
    // Row 4 (back of room)
    { id: 13, cx: 85,  cy: 660 },
    { id: 14, cx: 250, cy: 660 },
    { id: 15, cx: 460, cy: 660 },
    { id: 16, cx: 625, cy: 660 },
  ];

  /* ========== STATE ========== */
  let reservedSeats = new Set<string>();
  let selectedSeats: { table: number; seat: number }[] = [];
  let numGuests = 1;
  let hasAddon = false;

  function seatKey(table: number, seat: number) { return `${table}-${seat}`; }

  /* ========== HELPERS ========== */
  function genOrderId(): string {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
    let id = 'MC-';
    for (let i = 0; i < 6; i++) id += chars[Math.floor(Math.random() * chars.length)];
    return id;
  }

  function updatePrice() {
    numGuests = parseInt((document.getElementById('num-guests') as HTMLSelectElement).value) || 1;
    hasAddon = (document.getElementById('addon-package') as HTMLInputElement).checked;
    const base = BASE_PRICE * numGuests;
    const addon = hasAddon ? ADDON_PRICE : 0;
    const total = base + addon;

    document.getElementById('price-base')!.textContent = `$${BASE_PRICE} x ${numGuests} = $${base}`;
    document.getElementById('price-addon-row')!.style.display = hasAddon ? 'flex' : 'none';
    document.getElementById('price-total')!.textContent = `$${total}`;
    document.getElementById('checkout-venmo-amount')!.textContent = `$${total}`;

    // Show party note for addon
    const partyNote = document.getElementById('addon-party-note')!;
    partyNote.style.display = (hasAddon && numGuests > 1) ? 'block' : 'none';

    // If addon selected, enforce VIP tables only; clear selection if on non-VIP
    if (hasAddon && selectedSeats.length > 0 && !VIP_TABLES.includes(selectedSeats[0].table)) {
      selectedSeats = [];
      updateSeatDisplay();
      updateSeatSummary();
    }

    // Enforce seat count matches guest count
    while (selectedSeats.length > numGuests) {
      selectedSeats.pop();
    }
    updateSeatDisplay();
    updateSeatSummary();
  }

  /* ========== SEATING DIAGRAM ========== */
  function seatPosition(index: number, radius: number = 58) {
    const angle = (index * 60 - 90) * (Math.PI / 180);
    return { x: Math.cos(angle) * radius, y: Math.sin(angle) * radius };
  }

  function renderSeatingDiagram() {
    const container = document.getElementById('seating-diagram')!;
    container.innerHTML = '';

    const svgNS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(svgNS, 'svg');
    svg.setAttribute('viewBox', '0 0 710 740');
    svg.setAttribute('class', 'mc-seating__svg');

    // Stage
    const stageRect = document.createElementNS(svgNS, 'rect');
    stageRect.setAttribute('x', '155');
    stageRect.setAttribute('y', '10');
    stageRect.setAttribute('width', '400');
    stageRect.setAttribute('height', '40');
    stageRect.setAttribute('rx', '8');
    stageRect.setAttribute('fill', 'rgba(255,105,180,0.15)');
    stageRect.setAttribute('stroke', 'rgba(255,105,180,0.4)');
    stageRect.setAttribute('stroke-width', '1.5');
    svg.appendChild(stageRect);

    const stageText = document.createElementNS(svgNS, 'text');
    stageText.setAttribute('x', '355');
    stageText.setAttribute('y', '36');
    stageText.setAttribute('text-anchor', 'middle');
    stageText.setAttribute('fill', 'rgba(255,182,193,0.8)');
    stageText.setAttribute('font-size', '16');
    stageText.setAttribute('font-weight', '700');
    stageText.setAttribute('font-family', 'Inter, sans-serif');
    stageText.setAttribute('letter-spacing', '0.15em');
    stageText.textContent = 'STAGE';
    svg.appendChild(stageText);

    // Center hallway line
    const hallway = document.createElementNS(svgNS, 'line');
    hallway.setAttribute('x1', '355');
    hallway.setAttribute('y1', '60');
    hallway.setAttribute('x2', '355');
    hallway.setAttribute('y2', '720');
    hallway.setAttribute('stroke', 'rgba(255,255,255,0.06)');
    hallway.setAttribute('stroke-width', '1');
    hallway.setAttribute('stroke-dasharray', '6 4');
    svg.appendChild(hallway);

    TABLE_POSITIONS.forEach(table => {
      const g = document.createElementNS(svgNS, 'g');
      g.setAttribute('transform', `translate(${table.cx}, ${table.cy})`);

      const isVip = VIP_TABLES.includes(table.id);

      // Table circle
      const tableCircle = document.createElementNS(svgNS, 'circle');
      tableCircle.setAttribute('r', '42');
      tableCircle.setAttribute('fill', isVip ? 'rgba(212,175,55,0.08)' : 'rgba(255,255,255,0.03)');
      tableCircle.setAttribute('stroke', isVip ? '#D4AF37' : 'rgba(255,255,255,0.12)');
      tableCircle.setAttribute('stroke-width', isVip ? '2' : '1');
      g.appendChild(tableCircle);

      // Table number
      const label = document.createElementNS(svgNS, 'text');
      label.setAttribute('text-anchor', 'middle');
      label.setAttribute('dominant-baseline', 'central');
      label.setAttribute('fill', isVip ? '#D4AF37' : 'rgba(255,255,255,0.4)');
      label.setAttribute('font-size', '11');
      label.setAttribute('font-weight', '700');
      label.setAttribute('font-family', 'Inter, sans-serif');
      label.textContent = `Table #${table.id}`;
      g.appendChild(label);

      if (isVip) {
        const vipLabel = document.createElementNS(svgNS, 'text');
        vipLabel.setAttribute('text-anchor', 'middle');
        vipLabel.setAttribute('y', '14');
        vipLabel.setAttribute('fill', '#D4AF37');
        vipLabel.setAttribute('font-size', '8');
        vipLabel.setAttribute('font-weight', '700');
        vipLabel.setAttribute('font-family', 'Inter, sans-serif');
        vipLabel.setAttribute('letter-spacing', '0.1em');
        vipLabel.textContent = 'VIP';
        g.appendChild(vipLabel);
      }

      // Seats
      for (let s = 1; s <= 6; s++) {
        const pos = seatPosition(s - 1);
        const key = seatKey(table.id, s);
        const isReserved = reservedSeats.has(key);
        const isSelected = selectedSeats.some(ss => ss.table === table.id && ss.seat === s);

        const rotAngle = (s - 1) * 60;
        const seatG = document.createElementNS(svgNS, 'g');
        seatG.setAttribute('transform', `translate(${pos.x}, ${pos.y}) rotate(${rotAngle})`);
        seatG.setAttribute('data-table', `${table.id}`);
        seatG.setAttribute('data-seat', `${s}`);
        seatG.classList.add('mc-seat');

        if (isReserved) {
          seatG.classList.add('mc-seat--taken');
        } else if (isSelected) {
          seatG.classList.add('mc-seat--selected');
        } else {
          seatG.classList.add('mc-seat--available');
        }

        if (!isReserved) {
          seatG.addEventListener('click', () => handleSeatClick(table.id, s));
        }

        // Backrest (outer edge, faces away from table)
        const back = document.createElementNS(svgNS, 'rect');
        back.setAttribute('x', '-13');
        back.setAttribute('y', '-16');
        back.setAttribute('width', '26');
        back.setAttribute('height', '7');
        back.setAttribute('rx', '3.5');
        back.classList.add('mc-seat__back');
        seatG.appendChild(back);

        // Seat cushion
        const cushion = document.createElementNS(svgNS, 'rect');
        cushion.setAttribute('x', '-11');
        cushion.setAttribute('y', '-9');
        cushion.setAttribute('width', '22');
        cushion.setAttribute('height', '18');
        cushion.setAttribute('rx', '5');
        cushion.classList.add('mc-seat__cushion');
        seatG.appendChild(cushion);

        // Seat number
        const seatLabel = document.createElementNS(svgNS, 'text');
        seatLabel.setAttribute('x', '0');
        seatLabel.setAttribute('y', '1');
        seatLabel.setAttribute('text-anchor', 'middle');
        seatLabel.setAttribute('dominant-baseline', 'central');
        seatLabel.setAttribute('font-size', '10');
        seatLabel.setAttribute('font-weight', '600');
        seatLabel.setAttribute('font-family', 'Inter, sans-serif');
        seatLabel.setAttribute('pointer-events', 'none');
        seatLabel.setAttribute('transform', `rotate(${-rotAngle})`);
        seatLabel.classList.add('mc-seat__label');
        seatLabel.textContent = `${s}`;
        seatG.appendChild(seatLabel);

        g.appendChild(seatG);
      }

      svg.appendChild(g);
    });

    container.appendChild(svg);
  }

  function handleSeatClick(tableId: number, seatNum: number) {
    const key = seatKey(tableId, seatNum);
    if (reservedSeats.has(key)) return;

    // VIP tables (1-4) are only for addon package holders
    if (VIP_TABLES.includes(tableId) && !hasAddon) {
      showToast('Tables 2 and 3 are reserved for VIP Package holders');
      return;
    }

    // Check if clicking on a different table
    if (selectedSeats.length > 0 && selectedSeats[0].table !== tableId) {
      selectedSeats = [];
    }

    // Toggle seat
    const existingIdx = selectedSeats.findIndex(s => s.table === tableId && s.seat === seatNum);
    if (existingIdx >= 0) {
      selectedSeats.splice(existingIdx, 1);
    } else {
      if (selectedSeats.length >= numGuests) {
        showToast(`You can only select ${numGuests} seat${numGuests > 1 ? 's' : ''}`);
        return;
      }
      selectedSeats.push({ table: tableId, seat: seatNum });
    }

    updateSeatDisplay();
    updateSeatSummary();
  }

  function updateSeatDisplay() {
    document.querySelectorAll('.mc-seat').forEach(el => {
      const t = parseInt(el.getAttribute('data-table')!);
      const s = parseInt(el.getAttribute('data-seat')!);
      const key = seatKey(t, s);
      el.classList.remove('mc-seat--available', 'mc-seat--selected', 'mc-seat--taken');
      if (reservedSeats.has(key)) {
        el.classList.add('mc-seat--taken');
      } else if (selectedSeats.some(ss => ss.table === t && ss.seat === s)) {
        el.classList.add('mc-seat--selected');
      } else {
        el.classList.add('mc-seat--available');
      }
    });

  }

  function updateSeatSummary() {
    const summary = document.getElementById('seat-selection-summary')!;
    if (selectedSeats.length === 0) {
      summary.textContent = '';
      return;
    }
    const tableNum = selectedSeats[0].table;
    const seatNums = selectedSeats.map(s => `<span class="mc-seat-tag">${s.seat}</span>`).sort().join('');
    summary.innerHTML = `<span class="mc-seat-table-tag">Table #${tableNum}</span>${seatNums}`;
  }

  let toastTimeout: any;
  function showToast(msg: string) {
    let toast = document.getElementById('mc-toast');
    if (!toast) {
      toast = document.createElement('div');
      toast.id = 'mc-toast';
      toast.className = 'mc-toast';
      document.body.appendChild(toast);
    }
    toast.textContent = msg;
    toast.classList.add('mc-toast--show');
    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(() => toast!.classList.remove('mc-toast--show'), 3000);
  }

  /* ========== LOAD SEATS FROM SUPABASE ========== */
  async function loadSeats() {
    try {
      const { data } = await supabase
        .from('maidcafe_seats')
        .select('table_number, seat_number, status');

      reservedSeats.clear();
      if (data) {
        data.forEach((row: any) => {
          if (row.status === 'reserved') {
            reservedSeats.add(seatKey(row.table_number, row.seat_number));
          }
        });
      }
    } catch (e) {
      console.warn('Could not load seats from database:', e);
    }
    renderSeatingDiagram();
  }

  /* ========== REALTIME ========== */
  function setupRealtime() {
    try {
      supabase
        .channel('seats-live')
        .on('postgres_changes', {
          event: '*',
          schema: 'public',
          table: 'maidcafe_seats'
        }, (payload: any) => {
          const row = payload.new;
          if (!row) return;
          const key = seatKey(row.table_number, row.seat_number);
          if (row.status === 'reserved') {
            reservedSeats.add(key);
            selectedSeats = selectedSeats.filter(s => seatKey(s.table, s.seat) !== key);
          } else {
            reservedSeats.delete(key);
          }
          updateSeatDisplay();
          updateSeatSummary();
        })
        .subscribe();
    } catch (e) {
      console.warn('Could not setup realtime:', e);
    }
  }

  /* ========== CONTACT METHOD ========== */
  const contactInput = document.getElementById('contact-value') as HTMLInputElement;
  document.querySelectorAll<HTMLInputElement>('input[name="contact_method"]').forEach(r => {
    r.addEventListener('change', () => {
      if (r.value === 'email') {
        contactInput.style.display = 'none';
        contactInput.removeAttribute('required');
      } else {
        contactInput.style.display = 'block';
        contactInput.setAttribute('required', '');
        contactInput.placeholder = r.value === 'discord' ? 'Your Discord username' : 'Your phone number';
        contactInput.type = r.value === 'phone' ? 'tel' : 'text';
      }
    });
  });

  /* ========== STAFF SELECT ========== */
  const staffSelect = document.getElementById('staff-select') as HTMLSelectElement;
  const hiddenStaffId = document.getElementById('preferred-staff-id') as HTMLInputElement;
  staffSelect?.addEventListener('change', () => {
    hiddenStaffId.value = staffSelect.selectedOptions[0]?.dataset.id || '';
  });

  /* ========== GUEST INFO FIELDS ========== */
  function updateGuestFields() {
    const section = document.getElementById('guest-info-section')!;
    const container = document.getElementById('guest-info-fields')!;
    if (numGuests <= 1) {
      section.style.display = 'none';
      container.innerHTML = '';
      return;
    }
    section.style.display = 'block';
    container.innerHTML = '';
    for (let i = 2; i <= numGuests; i++) {
      const row = document.createElement('div');
      row.className = 'mc-guest-row';
      row.innerHTML = `
        <span class="mc-guest-row__num">Guest ${i}</span>
        <input type="text" name="guest_${i}_name" class="mc-input" placeholder="Full name" required />
        <select name="guest_${i}_affiliation" class="mc-input mc-select" required>
          <option value="student">UMD Student</option>
          <option value="alumni">Alumni</option>
          <option value="outside">Non UMD</option>
        </select>
      `;
      container.appendChild(row);
    }
    initCustomDropdowns();
  }

  /* ========== PRICE UPDATES ========== */
  document.getElementById('num-guests')!.addEventListener('change', () => { updatePrice(); updateGuestFields(); });
  document.getElementById('addon-package')!.addEventListener('change', updatePrice);

  /* ========== TERMS MODAL ========== */
  document.getElementById('terms-toggle')?.addEventListener('click', () => {
    document.getElementById('terms-modal')!.style.display = 'flex';
  });
  document.getElementById('terms-close')?.addEventListener('click', () => {
    document.getElementById('terms-modal')!.style.display = 'none';
  });

  /* ========== FORM + CONFIRMATION ========== */
  const form = document.getElementById('maidcafe-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const confirmModal = document.getElementById('confirm-modal')!;
  const confirmSummary = document.getElementById('confirm-summary')!;
  const confirmBack = document.getElementById('confirm-back')!;
  const confirmSubmit = document.getElementById('confirm-submit') as HTMLButtonElement;
  const successModal = document.getElementById('success-modal')!;
  const modalOid = document.getElementById('modal-order-id')!;
  const modalClose = document.getElementById('modal-close')!;

  let pendingPayload: Record<string, any> | null = null;
  let pendingOrderId = '';

  form.addEventListener('submit', (e) => {
    e.preventDefault();

    // Custom validation
    const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]');
    let firstInvalid: HTMLElement | null = null;
    form.querySelectorAll('.mc-field-error').forEach(el => el.remove());

    requiredFields.forEach(field => {
      field.classList.remove('mc-input--invalid');
      if (!field.value.trim()) {
        field.classList.add('mc-input--invalid');
        if (!firstInvalid) firstInvalid = field;
        const errMsg = document.createElement('p');
        errMsg.className = 'mc-field-error';
        errMsg.textContent = 'This field is required';
        field.parentNode!.appendChild(errMsg);
      }
    });

    // Check radio groups
    const contactMethod = form.querySelector<HTMLInputElement>('input[name="contact_method"]:checked');
    if (!contactMethod) {
      if (!firstInvalid) firstInvalid = form.querySelector('input[name="contact_method"]')!;
      showToast('Please select a preferred contact method');
    }

    if (firstInvalid) {
      firstInvalid.focus();
      firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    const fd = new FormData(form);
    pendingOrderId = genOrderId();

    // Validate seats
    if (selectedSeats.length === 0) {
      showToast('Please select your seats on the diagram');
      return;
    }
    if (selectedSeats.length !== numGuests) {
      showToast(`Please select exactly ${numGuests} seat${numGuests > 1 ? 's' : ''}`);
      return;
    }

    // Validate VIP table for addon
    if (hasAddon && !VIP_TABLES.includes(selectedSeats[0].table)) {
      showToast('VIP package holders must sit at Tables 2 and 3');
      return;
    }

    const totalPrice = BASE_PRICE * numGuests + (hasAddon ? ADDON_PRICE : 0);

    const affiliationLabels: Record<string, string> = { student: 'UMD Student', alumni: 'Alumni', outside: 'Non UMD' };

    // Collect additional guest info
    const guests: { name: string; affiliation: string }[] = [];
    for (let i = 2; i <= numGuests; i++) {
      guests.push({
        name: (fd.get(`guest_${i}_name`) as string) || '',
        affiliation: (fd.get(`guest_${i}_affiliation`) as string) || 'student',
      });
    }

    pendingPayload = {
      order_id: pendingOrderId,
      full_name: fd.get('full_name'),
      email: fd.get('email'),
      umd_affiliation: 'student',
      contact_method: fd.get('contact_method'),
      contact_value: fd.get('contact_method') === 'email' ? fd.get('email') : fd.get('contact_value'),
      num_guests: numGuests,
      additional_guests: guests.length > 0 ? guests : null,
      preferred_staff_name: fd.get('preferred_staff_name') || null,
      preferred_staff_id: fd.get('preferred_staff_id') || null,
      allergies: fd.get('allergies') || null,
      has_addon_package: hasAddon,
      total_price: totalPrice,
      table_number: selectedSeats[0].table,
      selected_seats: selectedSeats.map(s => ({ table_number: s.table, seat_number: s.seat })),
      agreed_to_terms: true,
      payment_status: 'pending',
      created_at: new Date().toISOString(),
    };

    const p = pendingPayload;
    const seatNums = selectedSeats.map(s => s.seat).sort().join(', ');
    const guestRows = guests.map((g, i) =>
      `<div class="mc-confirm-row"><span>Guest ${i + 2}</span><strong>${g.name} (${affiliationLabels[g.affiliation] || g.affiliation})</strong></div>`
    ).join('');

    confirmSummary.innerHTML = `
      <div class="mc-confirm-row"><span>Name</span><strong>${p.full_name}</strong></div>
      <div class="mc-confirm-row"><span>Email</span><strong>${p.email}</strong></div>
      <div class="mc-confirm-row"><span>Party Size</span><strong>${p.num_guests}</strong></div>
      ${guestRows}
      <div class="mc-confirm-row"><span>Seats</span><strong>Table ${p.table_number}, Seat${selectedSeats.length > 1 ? 's' : ''} ${seatNums}</strong></div>
      ${p.preferred_staff_name ? `<div class="mc-confirm-row"><span>Maid or Butler</span><strong>${p.preferred_staff_name}</strong></div>` : ''}
      ${p.has_addon_package ? `<div class="mc-confirm-row"><span>VIP Package</span><strong>Yes (+$10)</strong></div>` : ''}
      ${p.allergies ? `<div class="mc-confirm-row"><span>Allergies</span><strong>${p.allergies}</strong></div>` : ''}
    `;
    document.getElementById('checkout-venmo-amount')!.textContent = `$${pendingPayload?.total_price || 15}`;
    confirmModal.style.display = 'flex';
  });

  // Toggle event info inline
  document.getElementById('checkout-view-info')!.addEventListener('click', () => {
    const info = document.getElementById('checkout-event-info')!;
    const btn = document.getElementById('checkout-view-info')!;
    if (info.style.display === 'none') {
      info.style.display = 'block';
      btn.textContent = 'Hide Event Information';
    } else {
      info.style.display = 'none';
      btn.textContent = 'Review Event Information';
    }
  });

  confirmBack.addEventListener('click', () => { confirmModal.style.display = 'none'; });

  confirmSubmit.addEventListener('click', async () => {
    if (!pendingPayload) return;
    confirmSubmit.disabled = true;
    confirmSubmit.textContent = 'Submitting...';

    // 1. Insert reservation
    const { error: resError } = await supabase.from('maidcafe_reservations').insert(pendingPayload);
    if (resError) {
      alert(resError.code === '23505' ? 'A reservation with this email or order already exists.' : 'Something went wrong: ' + resError.message);
      confirmSubmit.disabled = false;
      confirmSubmit.textContent = 'Confirm Reservation';
      return;
    }

    // 2. Reserve seats atomically
    const { data: seatResult, error: seatError } = await supabase.rpc('reserve_seats', {
      p_order_id: pendingOrderId,
      p_seats: pendingPayload.selected_seats,
    });

    if (seatError || seatResult === false) {
      alert('Some of your selected seats were just taken. Please go back and choose different seats.');
      confirmSubmit.disabled = false;
      confirmSubmit.textContent = 'Confirm Reservation';
      confirmModal.style.display = 'none';
      await loadSeats();
      return;
    }

    // Success - show reservation details
    confirmModal.style.display = 'none';
    form.style.display = 'none';
    renderViewOrder(pendingPayload);
    document.getElementById('step-view-order')!.style.display = 'flex';
    document.querySelector('.mc__form-area')?.scrollTo(0, 0);
  });

  /* ========== CUSTOM DROPDOWNS ========== */
  function createCustomDropdown(select: HTMLSelectElement) {
    const wrapper = document.createElement('div');
    wrapper.className = 'mc-dropdown';

    const trigger = document.createElement('button');
    trigger.type = 'button';
    trigger.className = 'mc-dropdown__trigger';
    const selectedOpt = select.options[select.selectedIndex];
    trigger.innerHTML = `<span class="mc-dropdown__text">${selectedOpt?.text || 'Select'}</span><svg class="mc-dropdown__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,182,193,0.6)" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>`;

    const list = document.createElement('div');
    list.className = 'mc-dropdown__list';

    const children = select.children;
    for (let c = 0; c < children.length; c++) {
      const child = children[c];
      if (child.tagName === 'OPTGROUP') {
        const group = child as HTMLOptGroupElement;
        const groupLabel = document.createElement('div');
        groupLabel.className = 'mc-dropdown__group';
        groupLabel.textContent = group.label;
        list.appendChild(groupLabel);
        Array.from(group.querySelectorAll('option')).forEach(opt => addOption(opt));
      } else if (child.tagName === 'OPTION') {
        addOption(child as HTMLOptionElement);
      }
    }

    function addOption(opt: HTMLOptionElement) {
      const item = document.createElement('div');
      item.className = 'mc-dropdown__item' + (opt.selected ? ' mc-dropdown__item--active' : '');
      item.textContent = opt.text;
      item.dataset.value = opt.value;
      item.dataset.id = opt.dataset?.id || '';
      item.addEventListener('click', () => {
        select.value = opt.value;
        select.dispatchEvent(new Event('change', { bubbles: true }));
        trigger.querySelector('.mc-dropdown__text')!.textContent = opt.text;
        list.querySelectorAll('.mc-dropdown__item').forEach(el => el.classList.remove('mc-dropdown__item--active'));
        item.classList.add('mc-dropdown__item--active');
        wrapper.classList.remove('mc-dropdown--open');
      });
      list.appendChild(item);
    }

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      document.querySelectorAll('.mc-dropdown--open').forEach(d => { if (d !== wrapper) d.classList.remove('mc-dropdown--open'); });
      wrapper.classList.toggle('mc-dropdown--open');
    });

    select.style.display = 'none';
    wrapper.appendChild(trigger);
    wrapper.appendChild(list);
    select.parentNode!.insertBefore(wrapper, select.nextSibling);
  }

  function initCustomDropdowns() {
    document.querySelectorAll<HTMLSelectElement>('.mc-select:not([data-custom])').forEach(sel => {
      sel.setAttribute('data-custom', 'true');
      createCustomDropdown(sel);
    });
  }

  // Close dropdowns on outside click
  document.addEventListener('click', () => {
    document.querySelectorAll('.mc-dropdown--open').forEach(d => d.classList.remove('mc-dropdown--open'));
  });

  /* ========== INIT ========== */
  async function init() {
    initMenuAnimations();
    gsap.from('.mc__title', { y: 40, opacity: 0, duration: 0.6, ease: 'power3.out', delay: 0.15 });
    gsap.from('.mc__date', { y: 20, opacity: 0, duration: 0.5, ease: 'power3.out', delay: 0.3 });
    gsap.from('.mc__form-area', { y: 30, opacity: 0, duration: 0.6, ease: 'power3.out', delay: 0.25 });

    renderSeatingDiagram();
    updatePrice();
    loadSeats().then(() => setupRealtime());
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

