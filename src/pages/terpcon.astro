---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/navigation/Header.astro';
import terpcon from '../data/terpcon.json';

const { vendors, featuredArtists } = terpcon;
const defaultImage = terpcon.fallbackImage;
---

<BaseLayout title="TERPCON 2026 - Terrapin Anime Society">
  <Header />

  <main class="comic-page">
    <div class="comic-bg"></div>
    <div class="comic-overlay"></div>
    <div class="comic-content">
      <div class="comic-hero" data-comic-hero>
        <div class="comic-burst">
          <h1 class="comic-title" data-comic-title>{terpcon.title}</h1>
          <span class="comic-year">{terpcon.year}</span>
          <img src="/images/Icons/2.webp" alt="POW!" class="comic-pow" />
        </div>
        <p class="comic-tagline" data-comic-tagline>{terpcon.tagline}</p>
      </div>
      <div class="comic-columns">
        <div class="comic-left">
          <div class="comic-panel comic-panel--info" data-comic-info>
            <p class="comic-description">{terpcon.description}</p>

            <div class="comic-details-row">
              <div class="comic-details">
                <div class="comic-detail">
                  <span class="detail-label">DATE</span>
                  <span class="detail-value">{terpcon.date}</span>
                </div>
                <div class="comic-detail">
                  <span class="detail-label">TIME</span>
                  <span class="detail-value">{terpcon.time}</span>
                </div>
                <div class="comic-detail">
                  <span class="detail-label">LOCATION</span>
                  <span class="detail-value">{terpcon.location}</span>
                </div>
              </div>

              <a href={terpcon.ctaUrl} target="_blank" rel="noopener noreferrer" class="comic-cta">
                <span>{terpcon.ctaLabel}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </a>
            </div>
          </div>
          <div class="comic-panel comic-panel--featured" data-comic-featured>
            <h3 class="featured-title">FEATURED ARTISTS</h3>
            <div class="featured-carousel" data-featured-carousel>
              <div class="featured-track" data-featured-track>
                {featuredArtists.map((artist, index) => (
                  <div class="featured-card" data-featured-card={index}>
                    <div class="featured-card__image">
                      <img src={artist.artwork} alt={`Artwork by ${artist.name}`} />
                    </div>
                    <div class="featured-card__info">
                      <img src={artist.avatar} alt={artist.name} class="featured-card__avatar" />
                      <div class="featured-card__details">
                        <span class="featured-card__name">{artist.name}</span>
                        {artist.social ? (
                          <a href={artist.social} target="_blank" rel="noopener noreferrer" class="featured-card__social">{artist.socialDisplay}</a>
                        ) : (
                          <span class="featured-card__social">Find us at TerpCon!</span>
                        )}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
        <div class="comic-right">
          <div class="comic-panel comic-panel--vendors" data-comic-vendors>
            <h3 class="vendors-title">BROWSE ARTISTS</h3>
            <div class="vendors-scroll">
              <div class="vendors-grid">
                {vendors.map((vendor) => (
                  <div class="vendor-card">
                    <div class="vendor-avatar">
                      <img src={vendor.image || defaultImage} alt={vendor.name} loading="lazy" />
                    </div>
                    <h4 class={`vendor-name ${vendor.longName ? 'vendor-name--long' : ''}`}>{vendor.name}</h4>
                    {vendor.social ? (
                      <a href={vendor.social} target="_blank" rel="noopener noreferrer" class="vendor-social">
                        {vendor.socialDisplay}
                      </a>
                    ) : (
                      <span class="vendor-social vendor-social--none">Find us at TerpCon!</span>
                    )}
                    <p class="vendor-desc">{vendor.description}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  import gsap from 'gsap';
  import { initMenuAnimations } from '../animations/menu';

  function initAnimations() {
    initMenuAnimations();
    const hero = document.querySelector('[data-comic-hero]');
    const title = document.querySelector('[data-comic-title]');
    const info = document.querySelector('[data-comic-info]');
    const featured = document.querySelector('[data-comic-featured]');
    const featuredCards = document.querySelectorAll('[data-featured-card]');
    const vendors = document.querySelector('[data-comic-vendors]');

    gsap.set([hero, info, featured, vendors], { opacity: 0, y: 30 });
    gsap.set(title, { scale: 0.5, rotation: -10 });

    featuredCards.forEach((card, i) => {
      if (i < 4) {
        gsap.set(card, { x: 100 });
      } else {
        gsap.set(card, { display: 'none' });
      }
    });

    const tl = gsap.timeline({ defaults: { ease: 'back.out(1.7)' } });

    tl.to(hero, { opacity: 1, y: 0, duration: 0.5 }, 0)
      .to(title, { scale: 1, rotation: 0, duration: 0.6 }, 0.1)
      .to(info, { opacity: 1, y: 0, duration: 0.5 }, 0.3)
      .to(featured, { opacity: 1, y: 0, duration: 0.3 }, 0.4)
      .to(vendors, { opacity: 1, y: 0, duration: 0.5 }, 0.6);

    for (let i = 0; i < 4 && i < featuredCards.length; i++) {
      tl.to(featuredCards[i], {
        x: 0,
        duration: 0.5,
        ease: 'power2.out'
      }, 0.5 + i * 0.1);
    }

    tl.add(() => initCarousel(), 1.2);
  }

  function initCarousel() {
    const track = document.querySelector('[data-featured-track]') as HTMLElement;
    const cards = Array.from(document.querySelectorAll('[data-featured-card]')) as HTMLElement[];
    if (!track || cards.length <= 4) return;

    const totalCards = cards.length;
    let visibleStart = 0;

    function rotateCarousel() {
      const outgoingIndex = visibleStart;
      const incomingIndex = (visibleStart + 4) % totalCards;
      const outgoingCard = cards[outgoingIndex];
      const incomingCard = cards[incomingIndex];
      const cardWidth = outgoingCard.offsetWidth;
      const gap = 12;

      const rotateTl = gsap.timeline({
        onComplete: () => {
          gsap.set(outgoingCard, { display: 'none' });
          for (let i = 1; i <= 4; i++) {
            const idx = (visibleStart + i) % totalCards;
            gsap.set(cards[idx], { x: 0 });
          }
          visibleStart = (visibleStart + 1) % totalCards;
          setTimeout(rotateCarousel, 3500);
        }
      });

      for (let i = 0; i < 4; i++) {
        const idx = (visibleStart + i) % totalCards;
        rotateTl.to(cards[idx], {
          x: -(cardWidth + gap),
          duration: 0.6,
          ease: 'power2.inOut'
        }, 0);
      }

      gsap.set(incomingCard, { display: 'flex', x: 0 });
      rotateTl.to(incomingCard, {
        x: -(cardWidth + gap),
        duration: 0.6,
        ease: 'power2.inOut'
      }, 0);
    }

    setTimeout(rotateCarousel, 3500);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAnimations);
  } else {
    initAnimations();
  }
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bangers&display=swap');

  .comic-page {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #0a0a0a;
  }

  .comic-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/Backgrounds/comic background.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
  }

  .comic-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    z-index: 1;
  }

  .comic-overlay::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0,0,0,0.08) 1px, transparent 1px);
    background-size: 4px 4px;
    pointer-events: none;
  }

  .comic-content {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    padding: calc(5.19vh + 0.74vh) 0.8vw 1.11vh;
    box-sizing: border-box;
    overflow: hidden;
  }

  .comic-hero {
    text-align: center;
    margin-bottom: 0.74vh;
    flex-shrink: 0;
    opacity: 0;
    transform: translateY(2.22vh);
  }

  .comic-panel--info,
  .comic-panel--featured,
  .comic-panel--vendors {
    opacity: 0;
    transform: translateY(30px);
  }

  .comic-title {
    transform: scale(0.5) rotate(-10deg);
  }

  .comic-burst {
    display: inline-flex;
    align-items: baseline;
    gap: 0.33vw;
    position: relative;
  }

  .comic-title {
    font-family: 'Bangers', cursive;
    font-size: 6.67vw;
    font-weight: 400;
    color: #ffeb3b;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
    -webkit-text-stroke: 0.21vw #000;
    text-shadow:
      0.33vw 0.33vw 0 #ff6b35,
      0.67vw 0.67vw 0 #000;
    line-height: 0.85;
  }

  .comic-year {
    font-family: 'Bangers', cursive;
    font-size: 3.33vw;
    color: #00bcd4;
    -webkit-text-stroke: 0.13vw #000;
    text-shadow: 0.17vw 0.17vw 0 #000;
    transform: rotate(-8deg);
  }

  .comic-tagline {
    font-family: 'Bangers', cursive;
    font-size: 1.67vw;
    color: #fff;
    letter-spacing: 0.15em;
    margin: 0.37vh 0 0;
    text-shadow: 0.13vw 0.13vw 0 #000;
  }

  .comic-pow {
    position: absolute;
    width: 6.25vw;
    height: auto;
    right: -1.25vw;
    top: -1.48vh;
    transform: rotate(15deg);
    pointer-events: none;
    filter: drop-shadow(0.17vw 0.17vw 0 #000);
    z-index: -1;
  }

  .comic-columns {
    flex: 1;
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 1vw;
    min-height: 0;
  }

  .comic-left {
    display: flex;
    flex-direction: column;
    gap: 0.74vh;
    min-height: 0;
  }

  .comic-right {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .comic-panel {
    position: relative;
    background: rgba(0, 0, 0, 0.6);
    border: 0.17vw solid rgba(255, 107, 53, 0.8);
    border-radius: 0.5vw;
    overflow: hidden;
    box-shadow: 0 0.59vh 1.33vw rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(0.33vw);
  }

  .comic-panel--info {
    padding: 5vh 1.33vw;
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.48vh;
  }

  .comic-description {
    position: relative;
    z-index: 1;
    font-family: 'Inter', sans-serif;
    font-size: 0.92vw;
    font-weight: 500;
    color: #fff;
    line-height: 1.3;
    margin: 0;
  }

  .comic-details-row {
    display: flex;
    align-items: center;
    gap: 1vw;
    flex-wrap: wrap;
  }

  .comic-details {
    display: flex;
    gap: 0.67vw;
    flex-wrap: nowrap;
    align-items: center;
  }

  .comic-detail {
    display: flex;
    flex-direction: column;
    padding: 0.89vh 0.83vw;
    background: #ff6b35;
    border: 0.13vw solid #000;
    border-radius: 0.25vw;
    box-shadow: 0.13vw 0.13vw 0 #000;
  }

  .detail-label {
    font-family: 'Bangers', cursive;
    font-size: 0.58vw;
    color: #ffeb3b;
    letter-spacing: 0.08em;
  }

  .detail-value {
    font-family: 'Bangers', cursive;
    font-size: 0.92vw;
    color: #fff;
    letter-spacing: 0.03em;
  }

  .comic-cta {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.3vh;
    padding: 0.89vh 0.83vw;
    font-family: 'Bangers', cursive;
    font-size: 0.75vw;
    color: #000;
    background: #ffeb3b;
    border: 0.13vw solid #000;
    border-radius: 0.25vw;
    box-shadow: 0.13vw 0.13vw 0 #000;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .comic-cta:hover {
    transform: translate(-0.08vw, -0.15vh);
    box-shadow: 0.25vw 0.25vw 0 #000;
  }

  .comic-cta:active {
    transform: translate(0.08vw, 0.15vh);
    box-shadow: 0.08vw 0.08vw 0 #000;
  }

  .comic-panel--featured {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    padding: 0.74vh 0.67vw;
  }

  .featured-title {
    position: relative;
    z-index: 1;
    font-family: 'Bangers', cursive;
    font-size: 1.5vw;
    color: #ff6b35;
    letter-spacing: 0.1em;
    margin: 0 0 0.56vh;
    -webkit-text-stroke: 0.04vw #000;
    text-shadow: 0.08vw 0.08vw 0 #000;
  }

  .featured-carousel {
    flex: 1;
    overflow: hidden;
    min-height: 0;
    position: relative;
  }

  .featured-track {
    display: flex;
    gap: 0.5vw;
    height: 100%;
  }

  .featured-card {
    flex: 0 0 calc(25% - 0.375vw);
    min-width: 0;
    position: relative;
    border-radius: 0.33vw;
    overflow: hidden;
    border: 0.13vw solid #000;
    box-shadow: 0.17vw 0.17vw 0 #000;
    background: #111;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .featured-card__image {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .featured-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .featured-card__info {
    display: flex;
    align-items: center;
    gap: 0.33vw;
    padding: 0.37vh 0.33vw;
    background: rgba(0,0,0,0.95);
  }

  .featured-card__avatar {
    width: 2.08vw;
    height: 2.08vw;
    border-radius: 50%;
    object-fit: cover;
    border: 0.13vw solid #ff6b35;
    flex-shrink: 0;
  }

  .featured-card__details {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .featured-card__name {
    font-family: 'Bangers', cursive;
    font-size: 0.83vw;
    color: #fff;
    letter-spacing: 0.03em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .featured-card__social {
    font-family: 'Inter', sans-serif;
    font-size: 0.5vw;
    font-weight: 600;
    color: #00bcd4;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .featured-card__social:hover {
    color: #4dd0e1;
  }

  .comic-panel--vendors {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0.74vh 0.67vw;
    min-height: 0;
  }

  .vendors-title {
    position: relative;
    z-index: 1;
    font-family: 'Bangers', cursive;
    font-size: 1.67vw;
    color: #ff6b35;
    letter-spacing: 0.1em;
    margin: 0 0 0.56vh;
    text-align: center;
    -webkit-text-stroke: 0.04vw #000;
    text-shadow: 0.08vw 0.08vw 0 #000;
  }

  .vendors-scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    min-height: 0;
    padding-right: 0.33vw;
    scrollbar-width: thin;
    scrollbar-color: #ff6b35 #fff;
  }

  .vendors-scroll::-webkit-scrollbar {
    width: 0.33vw;
  }

  .vendors-scroll::-webkit-scrollbar-track {
    background: #fff;
    border: 0.08vw solid #000;
    border-radius: 0.17vw;
  }

  .vendors-scroll::-webkit-scrollbar-thumb {
    background: #ff6b35;
    border: 0.08vw solid #000;
    border-radius: 0.17vw;
  }

  .vendors-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.67vw;
    padding-bottom: 0.74vh;
  }

  .vendor-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0.74vh 0.67vw;
    background: rgba(0, 0, 0, 0.5);
    border: 0.08vw solid rgba(255, 107, 53, 0.5);
    border-radius: 0.5vw;
    transition: all 0.2s ease;
    aspect-ratio: 1 / 1;
  }

  .vendor-card:hover {
    transform: translateY(-0.3vh);
    background: rgba(0, 0, 0, 0.7);
    border-color: #ff6b35;
    box-shadow: 0 0.59vh 1vw rgba(255, 107, 53, 0.3);
  }

  .vendor-avatar {
    width: 50%;
    height: auto;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    overflow: hidden;
    border: 0.17vw solid #ff6b35;
    margin-bottom: 0.37vh;
    background: #222;
    flex-shrink: 0;
  }

  .vendor-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .vendor-name {
    font-family: 'Inter', sans-serif;
    font-size: 0.75vw;
    font-weight: 700;
    color: #fff;
    margin: 0;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .vendor-name--long {
    font-size: 0.63vw;
  }

  .vendor-social {
    font-family: 'Inter', sans-serif;
    font-size: 0.5vw;
    font-weight: 600;
    color: #ff6b35;
    text-decoration: none;
    margin: 0.15vh 0;
    word-break: break-all;
  }

  .vendor-social:hover {
    color: #00bcd4;
    text-decoration: underline;
  }

  .vendor-social--none {
    color: #999;
    font-style: italic;
  }

  .vendor-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.67vw;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.4;
    margin: 0.22vh 0 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 1100px) {
    .comic-columns {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .comic-content {
      padding: calc(70px + 8px) 16px 16px;
      overflow-y: auto;
    }

    .comic-hero {
      margin-bottom: 12px;
    }

    .comic-title {
      font-size: 56px;
      -webkit-text-stroke: 4px #000;
      text-shadow: 6px 6px 0 #ff6b35, 12px 12px 0 #000;
    }

    .comic-year {
      font-size: 28px;
      -webkit-text-stroke: 2px #000;
    }

    .comic-tagline {
      font-size: 18px;
      margin-top: 6px;
    }

    .comic-pow {
      width: 70px;
      right: -20px;
      top: -16px;
    }

    .comic-columns {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .comic-left, .comic-right {
      height: auto;
    }

    .comic-left {
      gap: 12px;
    }

    .comic-panel {
      border-width: 3px;
      border-radius: 10px;
    }

    .comic-panel--info {
      padding: 12px 16px;
      gap: 12px;
    }

    .comic-description {
      font-size: 14px;
    }

    .comic-details-row {
      gap: 12px;
    }

    .comic-details {
      gap: 8px;
    }

    .comic-detail {
      padding: 8px 12px;
      border-width: 2px;
      border-radius: 4px;
    }

    .detail-label {
      font-size: 10px;
    }

    .detail-value {
      font-size: 14px;
    }

    .comic-cta {
      padding: 8px 12px;
      font-size: 12px;
      border-width: 2px;
      border-radius: 4px;
    }

    .comic-panel--featured {
      min-height: 200px;
      padding: 12px;
    }

    .featured-title {
      font-size: 20px;
      margin-bottom: 8px;
    }

    .featured-track {
      gap: 10px;
    }

    .featured-card {
      flex: 0 0 calc(50% - 5px);
      border-width: 2px;
      border-radius: 6px;
    }

    .featured-card__info {
      padding: 6px;
      gap: 6px;
    }

    .featured-card__avatar {
      width: 32px;
      height: 32px;
      border-width: 2px;
    }

    .featured-card__name {
      font-size: 12px;
    }

    .featured-card__social {
      font-size: 9px;
    }

    .comic-panel--vendors {
      min-height: 350px;
      padding: 12px;
    }

    .vendors-title {
      font-size: 22px;
      margin-bottom: 10px;
    }

    .vendors-scroll {
      padding-right: 6px;
    }

    .vendors-scroll::-webkit-scrollbar {
      width: 6px;
    }

    .vendors-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      padding-bottom: 12px;
    }

    .vendor-card {
      padding: 10px;
      border-radius: 8px;
    }

    .vendor-avatar {
      border-width: 3px;
      margin-bottom: 6px;
    }

    .vendor-name {
      font-size: 12px;
